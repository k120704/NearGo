@page
@model NearGo.Pages.Checkout.IndexModel
@{
    ViewData["Title"] = "Thanh toán";
}
<div class="max-w-4xl mx-auto px-4 py-6">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">Thanh toán</h1>
    <form method="post" class="grid md:grid-cols-5 gap-6">
        <div class="md:col-span-3 space-y-4">
            <div class="bg-white dark:bg-gray-800 rounded-2xl p-6 shadow-sm border border-gray-100 dark:border-gray-700">
                <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Thông tin giao hàng</h2>
                <div class="space-y-3">
                    <div>
                        <label asp-for="Input.CustomerName" class="block text-sm font-medium text-gray-700 dark:text-gray-200 mb-1">Người nhận</label>
                        <input asp-for="Input.CustomerName" class="w-full px-4 py-2.5 border border-gray-200 dark:border-gray-600 rounded-xl bg-gray-50 dark:bg-gray-700 focus:ring-2 focus:ring-primary-500 outline-none text-sm" />
                        <span asp-validation-for="Input.CustomerName" class="text-xs text-red-500"></span>
                    </div>
                    <div>
                        <label asp-for="Input.CustomerPhone" class="block text-sm font-medium text-gray-700 dark:text-gray-200 mb-1">Số điện thoại</label>
                        <input asp-for="Input.CustomerPhone" class="w-full px-4 py-2.5 border border-gray-200 dark:border-gray-600 rounded-xl bg-gray-50 dark:bg-gray-700 focus:ring-2 focus:ring-primary-500 outline-none text-sm" />
                        <span asp-validation-for="Input.CustomerPhone" class="text-xs text-red-500"></span>
                    </div>
                    <div>
                        <label asp-for="Input.ShippingAddress" class="block text-sm font-medium text-gray-700 dark:text-gray-200 mb-1">Địa chỉ</label>
                        <input asp-for="Input.ShippingAddress" class="w-full px-4 py-2.5 border border-gray-200 dark:border-gray-600 rounded-xl bg-gray-50 dark:bg-gray-700 focus:ring-2 focus:ring-primary-500 outline-none text-sm" />
                        <span asp-validation-for="Input.ShippingAddress" class="text-xs text-red-500"></span>
                    </div>
                    <div>
                        <label asp-for="Input.Note" class="block text-sm font-medium text-gray-700 dark:text-gray-200 mb-1">Ghi chú</label>
                        <textarea asp-for="Input.Note" class="w-full px-4 py-2.5 border border-gray-200 dark:border-gray-600 rounded-xl bg-gray-50 dark:bg-gray-700 focus:ring-2 focus:ring-primary-500 outline-none text-sm" rows="2"></textarea>
                    </div>
                </div>
            </div>
            <div class="bg-white dark:bg-gray-800 rounded-2xl p-6 shadow-sm border border-gray-100 dark:border-gray-700">
                <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Phương thức thanh toán</h2>
                <div class="space-y-3">
                    <label class="flex items-center gap-3 p-4 border border-gray-200 dark:border-gray-600 rounded-xl cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
                        <input type="radio" asp-for="Input.PaymentMethod" value="COD" checked class="text-primary-500 focus:ring-primary-500" />
                        <div>
                            <span class="font-medium text-sm text-gray-900 dark:text-white">Thanh toán khi nhận hàng</span>
                            <p class="text-xs text-gray-400">Thanh toán bằng tiền mặt khi nhận hàng</p>
                        </div>
                    </label>
                    <label class="flex items-center gap-3 p-4 border border-gray-200 dark:border-gray-600 rounded-xl cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
                        <input type="radio" asp-for="Input.PaymentMethod" value="VNPay" class="text-primary-500 focus:ring-primary-500" />
                        <div>
                            <span class="font-medium text-sm text-gray-900 dark:text-white">VNPay</span>
                            <p class="text-xs text-gray-400">Chuyển khoản qua VNPay</p>
                        </div>
                    </label>
                    <label class="flex items-center gap-3 p-4 border border-gray-200 dark:border-gray-600 rounded-xl cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
                        <input type="radio" asp-for="Input.PaymentMethod" value="Momo" class="text-primary-500 focus:ring-primary-500" />
                        <div>
                            <span class="font-medium text-sm text-gray-900 dark:text-white">Momo</span>
                            <p class="text-xs text-gray-400">Thanh toán qua ví MoMo</p>
                        </div>
                    </label>
                </div>
                <span asp-validation-for="Input.PaymentMethod" class="text-xs text-red-500"></span>
            </div>
        </div>
        <div class="md:col-span-2">
            <div class="bg-white dark:bg-gray-800 rounded-2xl p-6 shadow-sm border border-gray-100 dark:border-gray-700 sticky top-20">
                <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Đơn hàng</h2>
                <div class="space-y-3 mb-4">
                    @foreach (var item in Model.CartItems)
                    {
                        <div class="flex items-center gap-3">
                            <img src="@item.Product.ImageUrl" alt="@item.Product.Name" class="w-12 h-12 rounded-lg object-cover" />
                            <div class="flex-1 min-w-0">
                                <p class="text-sm font-medium text-gray-900 dark:text-white truncate">@item.Product.Name</p>
                                <p class="text-xs text-gray-400">x@(item.Quantity)</p>
                            </div>
                            <span class="text-sm font-bold text-gray-900 dark:text-white">@((item.Product.DiscountedPrice * item.Quantity).ToString("N0"))đ</span>
                        </div>
                    }
                </div>
                <hr class="border-gray-100 dark:border-gray-700 mb-4" />
                <div class="space-y-2 text-sm">
                    <div class="flex justify-between">
                        <span class="text-gray-500">Tạm tính</span>
                        <span class="text-gray-900 dark:text-white">@Model.SubTotal.ToString("N0")đ</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-gray-500">Phí vận chuyển</span>
                        <span class="text-green-500">Miễn phí</span>
                    </div>
                </div>
                <hr class="border-gray-100 dark:border-gray-700 my-4" />
                <div class="flex justify-between items-center">
                    <span class="font-semibold text-gray-900 dark:text-white">Tổng cộng</span>
                    <span class="text-xl font-bold text-red-500">@Model.SubTotal.ToString("N0")đ</span>
                </div>
                <button type="submit" class="w-full mt-6 py-3 bg-gradient-to-r from-primary-500 to-primary-600 text-white font-medium rounded-xl hover:from-primary-600 hover:to-primary-700 shadow-md shadow-primary-500/20 transition-all">
                    <i class="fas fa-check mr-2"></i> Đặt hàng
                </button>
            </div>
        </div>
    </form>
</div>
