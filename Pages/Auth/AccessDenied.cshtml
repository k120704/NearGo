@page
@{
    ViewData["Title"] = "Truy cập bị từ chối";
    Layout = "_AuthLayout";
}
<div class="min-h-screen flex items-center justify-center bg-gray-50 dark:bg-gray-900 px-4">
    <div class="w-full max-w-md text-center" data-aos="fade-up">
        <div class="w-24 h-24 bg-red-100 dark:bg-red-900/30 rounded-full flex items-center justify-center mx-auto mb-6">
            <i class="fas fa-shield-halved text-4xl text-red-500"></i>
        </div>
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">403</h1>
        <p class="text-xl font-semibold text-gray-700 dark:text-gray-200 mb-2">Truy cập bị từ chối</p>
        <p class="text-gray-500 dark:text-gray-400 mb-8">Bạn không có quyền truy cập vào trang này.</p>
        <a href="/" class="inline-flex items-center gap-2 px-6 py-3 bg-primary-600 text-white font-medium rounded-xl hover:bg-primary-700 shadow-md transition-all">
            <i class="fas fa-home"></i> Về trang chủ
        </a>
