@page
@model NearGo.Pages.Auth.ChangePasswordModel
@{
    ViewData["Title"] = "Đổi mật khẩu";
    Layout = "_AuthLayout";
}
<div class="min-h-screen flex items-center justify-center bg-gray-50 dark:bg-gray-900 px-4">
    <div class="w-full max-w-md" data-aos="fade-up">
        <div class="text-center mb-8">
            <a href="/" class="inline-flex items-center gap-2 mb-6">
                <div class="w-12 h-12 bg-primary-700 rounded-2xl flex items-center justify-center shadow-lg">
                    <span class="text-white font-bold text-xl">N</span>
                </div>
                <span class="text-2xl font-bold text-primary-600 dark:text-primary-400">NearGo</span>
            </a>
            <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Đổi mật khẩu</h1>
            <p class="text-gray-500 dark:text-gray-400 mt-1">Cập nhật mật khẩu tài khoản của bạn</p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-3xl shadow-xl shadow-gray-200/50 dark:shadow-gray-900/50 p-8">
            @if (ViewData["Message"] != null)
            {
                <div class="mb-4 p-3 bg-success-50 dark:text-green-100 dark:bg-green-900/20 text-success-600 rounded-xl text-sm font-medium">
                    @ViewData["Message"]
                </div>
            }
            <form method="post" class="space-y-4">
                <div asp-validation-summary="ModelOnly" class="text-sm text-red-500 bg-red-50 dark:bg-red-900/20 rounded-xl p-3"></div>
                <div>
                    <label asp-for="Input.OldPassword" class="block text-sm font-medium text-gray-700 dark:text-gray-200 mb-2">Mật khẩu hiện tại</label>
                    <input asp-for="Input.OldPassword" class="w-full px-4 py-3 border border-gray-200 dark:border-gray-600 rounded-xl bg-gray-50 dark:bg-gray-700 focus:ring-2 focus:ring-primary-500 outline-none transition-all" />
                    <span asp-validation-for="Input.OldPassword" class="text-xs text-red-500 mt-1"></span>
                </div>
                <div>
                    <label asp-for="Input.NewPassword" class="block text-sm font-medium text-gray-700 dark:text-gray-200 mb-2">Mật khẩu mới</label>
                    <input asp-for="Input.NewPassword" class="w-full px-4 py-3 border border-gray-200 dark:border-gray-600 rounded-xl bg-gray-50 dark:bg-gray-700 focus:ring-2 focus:ring-primary-500 outline-none transition-all" />
                    <span asp-validation-for="Input.NewPassword" class="text-xs text-red-500 mt-1"></span>
                </div>
                <div>
                    <label asp-for="Input.ConfirmPassword" class="block text-sm font-medium text-gray-700 dark:text-gray-200 mb-2">Xác nhận mật khẩu mới</label>
                    <input asp-for="Input.ConfirmPassword" class="w-full px-4 py-3 border border-gray-200 dark:border-gray-600 rounded-xl bg-gray-50 dark:bg-gray-700 focus:ring-2 focus:ring-primary-500 outline-none transition-all" />
                    <span asp-validation-for="Input.ConfirmPassword" class="text-xs text-red-500 mt-1"></span>
                </div>
                <button type="submit" class="w-full py-3 bg-primary-600 text-white font-medium rounded-xl hover:bg-primary-700 shadow-md transition-all">
                    Đổi mật khẩu
                </button>
            </form>
        </div>
    </div>
</div>
