@page
@model NearGo.Pages.Auth.RegisterSupermarketModel
@{
    ViewData["Title"] = "Đăng ký siêu thị";
    Layout = "_AuthLayout";
}
<div class="min-h-screen flex items-center justify-center bg-gray-50 dark:bg-gray-900 px-4 py-12">
    <div class="w-full max-w-lg" data-aos="fade-up">
        <div class="text-center mb-8">
            <a href="/" class="inline-flex items-center gap-2 mb-6">
                <div class="w-12 h-12 bg-primary-700 rounded-2xl flex items-center justify-center shadow-lg">
                    <span class="text-white font-bold text-xl">N</span>
                </div>
                <span class="text-2xl font-bold text-primary-600 dark:text-primary-400">NearGo</span>
            </a>
            <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Đăng ký siêu thị đối tác</h1>
            <p class="text-gray-500 dark:text-gray-400 mt-1">Tham gia NearGo để bán sản phẩm cận date</p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-3xl shadow-xl shadow-gray-200/50 dark:shadow-gray-900/50 p-8">
            <form method="post" class="space-y-4">
                <div asp-validation-summary="ModelOnly" class="text-sm text-red-500 bg-red-50 dark:bg-red-900/20 rounded-xl p-3"></div>

                <div>
                    <label asp-for="Input.SupermarketName" class="block text-sm font-medium text-gray-700 dark:text-gray-200 mb-2">Tên siêu thị</label>
                    <input asp-for="Input.SupermarketName" class="w-full px-4 py-3 border border-gray-200 dark:border-gray-600 rounded-xl bg-gray-50 dark:bg-gray-700 focus:ring-2 focus:ring-primary-500 focus:border-transparent outline-none transition-all" placeholder="Siêu thị XYZ" />
                    <span asp-validation-for="Input.SupermarketName" class="text-xs text-red-500 mt-1"></span>
                </div>

                <div>
                    <label asp-for="Input.Email" class="block text-sm font-medium text-gray-700 dark:text-gray-200 mb-2">Email đăng nhập</label>
                    <input asp-for="Input.Email" class="w-full px-4 py-3 border border-gray-200 dark:border-gray-600 rounded-xl bg-gray-50 dark:bg-gray-700 focus:ring-2 focus:ring-primary-500 focus:border-transparent outline-none transition-all" placeholder="supermarket@example.com" />
                    <span asp-validation-for="Input.Email" class="text-xs text-red-500 mt-1"></span>
                </div>

                <div>
                    <label asp-for="Input.Phone" class="block text-sm font-medium text-gray-700 dark:text-gray-200 mb-2">Số điện thoại</label>
                    <input asp-for="Input.Phone" class="w-full px-4 py-3 border border-gray-200 dark:border-gray-600 rounded-xl bg-gray-50 dark:bg-gray-700 focus:ring-2 focus:ring-primary-500 focus:border-transparent outline-none transition-all" placeholder="0901234567" />
                    <span asp-validation-for="Input.Phone" class="text-xs text-red-500 mt-1"></span>
                </div>

                <div>
                    <label asp-for="Input.Address" class="block text-sm font-medium text-gray-700 dark:text-gray-200 mb-2">Địa chỉ</label>
                    <input asp-for="Input.Address" class="w-full px-4 py-3 border border-gray-200 dark:border-gray-600 rounded-xl bg-gray-50 dark:bg-gray-700 focus:ring-2 focus:ring-primary-500 focus:border-transparent outline-none transition-all" placeholder="123 Nguyễn Huệ, Quận 1, TP.HCM" />
                    <span asp-validation-for="Input.Address" class="text-xs text-red-500 mt-1"></span>
                </div>

                <div>
                    <label asp-for="Input.TaxCode" class="block text-sm font-medium text-gray-700 dark:text-gray-200 mb-2">Mã số thuế</label>
                    <input asp-for="Input.TaxCode" class="w-full px-4 py-3 border border-gray-200 dark:border-gray-600 rounded-xl bg-gray-50 dark:bg-gray-700 focus:ring-2 focus:ring-primary-500 focus:border-transparent outline-none transition-all" placeholder="Mã số thuế (không bắt buộc)" />
                </div>

                <div>
                    <label asp-for="Input.Description" class="block text-sm font-medium text-gray-700 dark:text-gray-200 mb-2">Mô tả</label>
                    <textarea asp-for="Input.Description" class="w-full px-4 py-3 border border-gray-200 dark:border-gray-600 rounded-xl bg-gray-50 dark:bg-gray-700 focus:ring-2 focus:ring-primary-500 focus:border-transparent outline-none transition-all" rows="3" placeholder="Giới thiệu về siêu thị (không bắt buộc)"></textarea>
                </div>

                <div class="p-4 bg-primary-50 dark:bg-primary-900/20 rounded-xl text-sm text-primary-700 dark:text-primary-200">
                    <i class="fas fa-info-circle mr-1"></i> Mật khẩu sẽ được gửi vào email của bạn sau khi đăng ký thành công.
                </div>

                <button type="submit" class="w-full py-3 bg-primary-600 text-white font-medium rounded-xl hover:bg-primary-700 shadow-md hover:shadow-lg transition-all">
                    <i class="fas fa-store mr-2"></i> Đăng ký siêu thị
                </button>
            </form>
            <div class="mt-6 text-center space-y-2">
                <p class="text-sm text-gray-500 dark:text-gray-400">
                    Đã có tài khoản?
                    <a href="/auth/login" class="text-primary-600 hover:text-primary-700 font-medium">Đăng nhập</a>
                </p>
                <p class="text-sm text-gray-500 dark:text-gray-400">
                    Bạn là khách hàng?
                    <a href="/auth/register" class="text-primary-600 hover:text-primary-700 font-medium">Đăng ký tài khoản khách hàng</a>
                </p>
            </div>
        </div>
    </div>
</div>
