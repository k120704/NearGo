@page
@model NearGo.Pages.Cart.IndexModel
@{
    ViewData["Title"] = "Giỏ hàng";
}
<div class="max-w-7xl mx-auto px-4 py-6">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">Giỏ hàng của tôi</h1>
    @if (!Model.CartItems.Any())
    {
        <div class="text-center py-16 bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700">
            <div class="w-20 h-20 bg-gray-100 dark:bg-gray-700 rounded-full flex items-center justify-center mx-auto mb-4">
                <i class="fas fa-shopping-cart text-3xl text-gray-400"></i>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-1">Giỏ hàng trống</h3>
            <p class="text-sm text-gray-500 mb-4">Khám phá sản phẩm và thêm vào giỏ hàng</p>
            <a href="/products" class="inline-flex items-center gap-2 px-6 py-2.5 bg-primary-500 text-white rounded-xl hover:bg-primary-600 transition-colors">
                <i class="fas fa-shopping-bag"></i> Mua sắm ngay
            </a>
        </div>
    }
    else
    {
        var groupedItems = Model.CartItems.GroupBy(c => c.Product.Supermarket?.Name ?? "Khác");
        <form method="post" asp-page-handler="Checkout">
            @foreach (var group in groupedItems)
            {
                <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 mb-4 overflow-hidden">
                    <div class="p-4 border-b border-gray-100 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50">
                        <div class="flex items-center gap-2">
                            <i class="fas fa-store text-primary-500"></i>
                            <span class="font-semibold text-gray-900 dark:text-white text-sm">@group.Key</span>
                        </div>
                    </div>
                    @foreach (var item in group)
                    {
                        <div class="flex items-center gap-4 p-4 border-b border-gray-100 dark:border-gray-700 last:border-0">
                            <div class="w-16 h-16 rounded-xl overflow-hidden bg-gray-100 dark:bg-gray-700 shrink-0">
                                <img src="@item.Product.ImageUrl" alt="@item.Product.Name" class="w-full h-full object-cover" />
                            </div>
                            <div class="flex-1 min-w-0">
                                <a href="/products/detail?id=@item.Product.Id" class="text-sm font-semibold text-gray-900 dark:text-white truncate block hover:text-primary-600">@item.Product.Name</a>
                                <p class="text-xs text-gray-400">@item.Product.Unit, @item.Product.Origin</p>
                                <div class="flex items-center gap-2 mt-1">
                                    <span class="text-sm font-bold text-red-500">@item.Product.DiscountedPrice.ToString("N0")đ</span>
                                    @if (item.Product.DiscountPercentage > 0)
                                    {
                                        <span class="text-xs text-gray-400 line-through">@item.Product.OriginalPrice.ToString("N0")đ</span>
                                    }
                                </div>
                            </div>
                            <div class="flex items-center gap-3">
                                <div class="flex items-center border border-gray-200 dark:border-gray-600 rounded-lg overflow-hidden">
                                    <button type="button" onclick="updateCart(@item.Id, @(item.Quantity - 1))" class="px-2 py-1 hover:bg-gray-100 dark:hover:bg-gray-700 text-xs"><i class="fas fa-minus"></i></button>
                                    <span class="px-3 py-1 text-xs font-medium bg-transparent">@item.Quantity</span>
                                    <button type="button" onclick="updateCart(@item.Id, @(item.Quantity + 1))" class="px-2 py-1 hover:bg-gray-100 dark:hover:bg-gray-700 text-xs"><i class="fas fa-plus"></i></button>
                                </div>
                                <button type="button" onclick="removeCart(@item.Id)" class="p-2 text-gray-400 hover:text-red-500 transition-colors">
                                    <i class="fas fa-trash-can text-xs"></i>
                                </button>
                            </div>
                        </div>
                    }
                </div>
            }
            <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 p-6">
                <div class="flex items-center justify-between mb-4">
                    <span class="text-gray-600 dark:text-gray-300">Tạm tính:</span>
                    <span class="text-lg font-bold text-gray-900 dark:text-white">@Model.Total.ToString("N0")đ</span>
                </div>
                <button type="submit" class="w-full py-3 bg-primary-600 text-white font-medium rounded-xl hover:bg-primary-700 shadow-md transition-all">
                    <i class="fas fa-credit-card mr-2"></i> Tiến hành thanh toán
                </button>
            </div>
        </form>
    }
</div>
<script>
    async function updateCart(id, qty) {
        if (qty < 0) qty = 0;
        var resp = await fetch('/cart/cartapi?handler=update', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: 'id=' + id + '&quantity=' + qty
        });
        if (resp.ok) location.reload();
    }
    async function removeCart(id) {
        var resp = await fetch('/cart/cartapi?handler=remove', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: 'id=' + id
        });
        if (resp.ok) location.reload();
    }
</script>
