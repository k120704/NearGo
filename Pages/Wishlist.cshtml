@page
@model NearGo.Pages.WishlistModel
@{
    ViewData["Title"] = "Siêu thị theo dõi";
}
<div class="max-w-7xl mx-auto px-4 py-6">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">Siêu thị đang theo dõi</h1>
    @if (!Model.FollowedSupermarkets.Any())
    {
        <div class="text-center py-16 bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700">
            <div class="w-20 h-20 bg-gray-100 dark:bg-gray-700 rounded-full flex items-center justify-center mx-auto mb-4">
                <i class="fas fa-store text-3xl text-gray-400"></i>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-1">Chưa theo dõi siêu thị nào</h3>
            <p class="text-sm text-gray-500 mb-4">Theo dõi siêu thị để nhận thông báo sản phẩm mới</p>
            <a href="/supermarkets" class="inline-flex items-center gap-2 px-6 py-2.5 bg-primary-500 text-white rounded-xl hover:bg-primary-600">Khám phá ngay</a>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            @foreach (var sm in Model.FollowedSupermarkets)
            {
                <div class="bg-white dark:bg-gray-800 rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-all border border-gray-100 dark:border-gray-700">
                    <div class="p-5">
                        <div class="flex items-center gap-4 mb-3">
                            <div class="w-14 h-14 rounded-xl overflow-hidden bg-gray-100 dark:bg-gray-700 shrink-0">
                                <img src="@sm.LogoUrl" alt="@sm.Name" class="w-full h-full object-cover" loading="lazy" />
                            </div>
                            <div class="min-w-0">
                                <h3 class="font-semibold text-gray-900 dark:text-white truncate">@sm.Name</h3>
                                <div class="flex items-center gap-1 mt-0.5">
                                    @for (int i = 0; i < 5; i++)
                                    {
                                        <i class="fas fa-star text-xs @(i < Math.Round(sm.Rating) ? "text-yellow-400" : "text-gray-200 dark:text-gray-600")"></i>
                                    }
                                    <span class="text-xs text-gray-400 ml-1">@sm.Rating.ToString("0.0")</span>
                                </div>
                            </div>
                        </div>
                        <p class="text-sm text-gray-500 dark:text-gray-400 line-clamp-2 mb-3">@sm.Description</p>
                        <div class="flex items-center justify-between">
                            <a href="/supermarkets/detail?slug=@sm.Slug" class="text-sm text-primary-600 hover:text-primary-700 font-medium">
                                Xem siêu thị <i class="fas fa-arrow-right ml-1 text-xs"></i>
                            </a>
                            <form method="post" asp-page-handler="ToggleFollow" asp-route-supermarketId="@sm.Id">
                                <button type="submit" class="px-3 py-1.5 text-sm font-medium text-red-600 bg-red-50 dark:bg-red-900/20 rounded-xl hover:bg-red-100 dark:hover:bg-red-900/40 transition-colors">
                                    <i class="fas fa-times mr-1"></i>Bỏ theo dõi
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
