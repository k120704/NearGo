@page
@model NearGo.Pages.Products.DetailModel
@{
    ViewData["Title"] = Model.Product?.Name ?? "Chi tiết sản phẩm";
}
@if (Model.Product == null)
{
    <div class="max-w-7xl mx-auto px-4 py-16 text-center">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Sản phẩm không tồn tại</h2>
        <a href="/products" class="mt-4 inline-block text-primary-500 hover:text-primary-600">Quay lại danh sách</a>
    </div>
    return;
}
<div class="max-w-7xl mx-auto px-4 py-6">
    <nav class="flex items-center gap-2 text-sm text-gray-500 mb-6">
        <a href="/" class="hover:text-primary-600">Trang chủ</a>
        <i class="fas fa-chevron-right text-xs"></i>
        <a href="/products" class="hover:text-primary-600">Sản phẩm</a>
        <i class="fas fa-chevron-right text-xs"></i>
        <a href="/products?category=@Model.Product.Category?.Slug" class="hover:text-primary-600">@Model.Product.Category?.Name</a>
        <i class="fas fa-chevron-right text-xs"></i>
        <span class="text-gray-900 dark:text-white truncate">@Model.Product.Name</span>
    </nav>
    <div class="grid md:grid-cols-2 gap-8">
        <div data-aos="fade-right">
            <div class="bg-white dark:bg-gray-800 rounded-2xl overflow-hidden shadow-sm border border-gray-100 dark:border-gray-700">
                <img src="@Model.Product.ImageUrl" alt="@Model.Product.Name" class="w-full h-80 md:h-96 object-cover" />
            </div>
        </div>
        <div data-aos="fade-left">
            <div class="bg-white dark:bg-gray-800 rounded-2xl p-6 shadow-sm border border-gray-100 dark:border-gray-700">
                <div class="flex items-center gap-2 mb-2">
                    <span class="text-xs px-2 py-0.5 rounded-full bg-primary-50 dark:bg-primary-900/20 text-primary-600 dark:text-primary-300 font-medium">@Model.Product.Supermarket?.Name</span>
                    @if (Model.Product.IsBoosted)
                    {
                        <span class="text-xs px-2 py-0.5 rounded-full bg-accent-50 dark:bg-accent-900/20 text-accent-600 dark:text-accent-300 font-medium"><i class="fas fa-bolt mr-1"></i>Boost</span>
                    }
                </div>
                <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">@Model.Product.Name</h1>
                <div class="flex items-center gap-3 mb-4">
                    <div class="flex items-center gap-1">
                        @for (int i = 0; i < 5; i++)
                        {
                            <i class="fas fa-star text-xs @(i < 4 ? "text-yellow-400" : "text-gray-200 dark:text-gray-600")"></i>
                        }
                        <span class="text-xs text-gray-500 ml-1">(4.0)</span>
                    </div>
                    <span class="text-xs text-gray-400"><i class="far fa-eye mr-1"></i>@Model.Product.ViewCount lượt xem</span>
                    <span class="text-xs text-gray-400"><i class="fas fa-shopping-bag mr-1"></i>Đã bán @Model.Product.SoldCount</span>
                </div>
                <div class="flex items-baseline gap-3 mb-6">
                    <span class="text-3xl font-bold text-red-500">@Model.Product.DiscountedPrice.ToString("N0")đ</span>
                    @if (Model.Product.DiscountPercentage > 0)
                    {
                        <span class="text-lg text-gray-400 line-through">@Model.Product.OriginalPrice.ToString("N0")đ</span>
                        <span class="px-2 py-0.5 bg-red-50 dark:bg-red-900/20 text-red-500 text-xs font-bold rounded-lg">-@((int)Model.Product.DiscountPercentage)%</span>
                    }
                </div>
                <div class="grid grid-cols-2 gap-4 mb-6">
                    <div class="bg-gray-50 dark:bg-gray-700/50 rounded-xl p-3">
                        <p class="text-xs text-gray-500">Hạn sử dụng</p>
                        <p class="text-sm font-semibold text-gray-900 dark:text-white">@Model.Product.ExpiryDate.ToString("dd/MM/yyyy")</p>
                    </div>
                    <div class="bg-gray-50 dark:bg-gray-700/50 rounded-xl p-3">
                        <p class="text-xs text-gray-500">Còn lại</p>
                        <p class="text-sm font-semibold text-gray-900 dark:text-white">@Math.Max(0, (Model.Product.ExpiryDate - DateTime.UtcNow).Days) ngày</p>
                    </div>
                    <div class="bg-gray-50 dark:bg-gray-700/50 rounded-xl p-3">
                        <p class="text-xs text-gray-500">Kho</p>
                        <p class="text-sm font-semibold text-gray-900 dark:text-white">@Model.Product.StockQuantity @Model.Product.Unit</p>
                    </div>
                    <div class="bg-gray-50 dark:bg-gray-700/50 rounded-xl p-3">
                        <p class="text-xs text-gray-500">Xuất xứ</p>
                        <p class="text-sm font-semibold text-gray-900 dark:text-white">@Model.Product.Origin</p>
                    </div>
                </div>
                <div class="flex items-center gap-4 mb-6">
                    <div class="flex items-center border border-gray-200 dark:border-gray-600 rounded-xl overflow-hidden">
                        <button onclick="updateQty(-1)" class="px-3 py-2 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors"><i class="fas fa-minus text-xs"></i></button>
                        <input type="number" id="qty" value="1" min="1" max="@Model.Product.StockQuantity" class="w-12 text-center py-2 text-sm font-medium bg-transparent border-x border-gray-200 dark:border-gray-600 outline-none" />
                        <button onclick="updateQty(1)" class="px-3 py-2 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors"><i class="fas fa-plus text-xs"></i></button>
                    </div>
                    <button onclick="addToCart(@Model.Product.Id, document.getElementById('qty').value)" class="flex-1 py-3 bg-primary-600 text-white font-medium rounded-xl hover:bg-primary-700 shadow-md transition-all">
                        <i class="fas fa-shopping-cart mr-2"></i>Thêm vào giỏ
                    </button>
                </div>
                <hr class="border-gray-100 dark:border-gray-700 mb-4" />
                <div class="space-y-3 text-sm text-gray-600 dark:text-gray-300">
                    <p><i class="fas fa-truck text-primary-500 w-5"></i> Giao hàng toàn quốc</p>
                    <p><i class="fas fa-shield text-primary-500 w-5"></i> Đảm bảo chất lượng, hoàn tiền nếu không hài lòng</p>
                    <p><i class="fas fa-rotate-left text-primary-500 w-5"></i> Đổi trả trong 3 ngày</p>
                </div>
            </div>
        </div>
    </div>
    @if (!string.IsNullOrEmpty(Model.Product.Description))
    {
        <div class="bg-white dark:bg-gray-800 rounded-2xl p-6 shadow-sm border border-gray-100 dark:border-gray-700 mt-6" data-aos="fade-up">
            <h2 class="text-lg font-bold text-gray-900 dark:text-white mb-4">Mô tả sản phẩm</h2>
            <p class="text-sm text-gray-600 dark:text-gray-300 leading-relaxed">@Model.Product.Description</p>
        </div>
    }
    @if (Model.RelatedProducts.Any())
    {
        <div class="mt-8" data-aos="fade-up">
            <h2 class="text-lg font-bold text-gray-900 dark:text-white mb-4">Sản phẩm liên quan</h2>
            <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-4">
                @foreach (var p in Model.RelatedProducts)
                {
                    <a href="/products/detail?id=@p.Id" class="bg-white dark:bg-gray-800 rounded-xl overflow-hidden shadow-sm hover:shadow-lg transition-all group border border-gray-100 dark:border-gray-700">
                        <img src="@p.ImageUrl" alt="@p.Name" class="w-full h-28 object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
                        <div class="p-2.5">
                            <h3 class="text-xs font-semibold text-gray-900 dark:text-white truncate">@p.Name</h3>
                            <span class="text-sm font-bold text-red-500">@p.DiscountedPrice.ToString("N0")đ</span>
                        </div>
                    </a>
                }
            </div>
        </div>
    }
</div>
<script>
    function updateQty(delta) {
        var qty = document.getElementById('qty');
        var val = parseInt(qty.value) + delta;
        if (val < 1) val = 1;
        if (val > @Model.Product.StockQuantity) val = @Model.Product.StockQuantity;
        qty.value = val;
    }
</script>
