@{
    Layout = "_Layout";
}
<div class="max-w-7xl mx-auto px-4 py-6 grid grid-cols-1 md:grid-cols-5 gap-6">
    <aside class="md:col-span-1">
        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 overflow-hidden sticky top-20">
            <div class="p-4 bg-gradient-to-r from-primary-600 via-primary-500 to-accent-500 text-white text-center">
                <div class="w-14 h-14 bg-white/20 rounded-xl flex items-center justify-center mx-auto mb-2">
                    <i class="fas fa-shield-halved text-2xl"></i>
                </div>
                <p class="font-semibold text-sm">Admin Panel</p>
                <p class="text-white/60 text-xs">Quản trị hệ thống</p>
            </div>
            <nav class="p-2 space-y-1">
                <a href="/admin/dashboard" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm @(Context.Request.Path == "/admin/dashboard" ? "bg-primary-50 dark:bg-primary-900/20 text-primary-600 font-medium" : "text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700")">
                    <i class="fas fa-tachometer-alt w-5"></i> Dashboard
                </a>
                <a href="/admin/supermarkets" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm @(Context.Request.Path.StartsWithSegments("/admin/supermarkets") ? "bg-primary-50 dark:bg-primary-900/20 text-primary-600 font-medium" : "text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700")">
                    <i class="fas fa-store w-5"></i> Siêu thị
                </a>
                <a href="/admin/categories" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm @(Context.Request.Path.StartsWithSegments("/admin/categories") ? "bg-primary-50 dark:bg-primary-900/20 text-primary-600 font-medium" : "text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700")">
                    <i class="fas fa-tags w-5"></i> Danh mục
                </a>
                <a href="/admin/fees" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm @(Context.Request.Path == "/admin/fees" ? "bg-primary-50 dark:bg-primary-900/20 text-primary-600 font-medium" : "text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700")">
                    <i class="fas fa-dollar-sign w-5"></i> Phí nền tảng
                </a>
                <hr class="border-gray-100 dark:border-gray-700 my-2" />
                <a asp-page="/Auth/ChangePassword" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700">
                    <i class="fas fa-lock w-5"></i> Đổi mật khẩu
                </a>
            </nav>
        </div>
    </aside>
    <main class="md:col-span-4">
        @RenderBody()
    </main>
</div>

@await RenderSectionAsync("Scripts", required: false)
