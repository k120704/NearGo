@{
    Layout = "_Layout";
}
<div class="max-w-7xl mx-auto px-4 py-6 grid grid-cols-1 md:grid-cols-5 gap-6">
    <aside class="md:col-span-1">
        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 overflow-hidden sticky top-20">
            <div class="p-4 bg-gradient-to-r from-primary-500 to-primary-600 text-white text-center">
                @{
                    var user = await UserManager.GetUserAsync(User);
                }
                <div class="w-14 h-14 bg-white/20 rounded-xl flex items-center justify-center mx-auto mb-2">
                    <i class="fas fa-store text-2xl"></i>
                </div>
                <p class="font-semibold text-sm">Quản lý siêu thị</p>
                <p class="text-white/60 text-xs">@user?.Email</p>
            </div>
            <nav class="p-2 space-y-1">
                <a href="/supermarket/dashboard" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm @(Context.Request.Path == "/supermarket/dashboard" ? "bg-primary-50 dark:bg-primary-900/20 text-primary-600 font-medium" : "text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700")">
                    <i class="fas fa-tachometer-alt w-5"></i> Dashboard
                </a>
                <a href="/supermarket/products" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm @(Context.Request.Path.StartsWithSegments("/supermarket/products") ? "bg-primary-50 dark:bg-primary-900/20 text-primary-600 font-medium" : "text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700")">
                    <i class="fas fa-box w-5"></i> Sản phẩm
                </a>
                <a href="/supermarket/orders" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm @(Context.Request.Path.StartsWithSegments("/supermarket/orders") ? "bg-primary-50 dark:bg-primary-900/20 text-primary-600 font-medium" : "text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700")">
                    <i class="fas fa-clipboard-list w-5"></i> Đơn hàng
                </a>
                <a href="/supermarket/revenue" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm @(Context.Request.Path == "/supermarket/revenue" ? "bg-primary-50 dark:bg-primary-900/20 text-primary-600 font-medium" : "text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700")">
                    <i class="fas fa-dollar-sign w-5"></i> Doanh thu
                </a>
                <a href="/supermarket/banners" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm @(Context.Request.Path.StartsWithSegments("/supermarket/banners") ? "bg-primary-50 dark:bg-primary-900/20 text-primary-600 font-medium" : "text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700")">
                    <i class="fas fa-images w-5"></i> Quảng cáo Banner
                </a>
                <hr class="border-gray-100 dark:border-gray-700 my-2" />
                <a href="/supermarket/upgrade" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm @(Context.Request.Path == "/supermarket/upgrade" ? "bg-primary-50 dark:bg-primary-900/20 text-primary-600 font-medium" : "text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700")">
                    <i class="fas fa-crown w-5"></i> Nâng cấp gói
                </a>
                <a asp-page="/Auth/ChangePassword" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700">
                    <i class="fas fa-lock w-5"></i> Đổi mật khẩu
                </a>
            </nav>
        </div>
    </aside>
    <main class="md:col-span-4">
        @if (TempData["Success"] != null)
        {
            <div class="mb-4 p-3 bg-green-100 text-green-700 rounded-lg text-sm">@TempData["Success"]</div>
        }
        @if (TempData["Info"] != null)
        {
            <div class="mb-4 p-3 bg-blue-100 text-blue-700 rounded-lg text-sm">@TempData["Info"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="mb-4 p-3 bg-red-100 text-red-700 rounded-lg text-sm">@TempData["Error"]</div>
        }
        @RenderBody()
    </main>
</div>

@await RenderSectionAsync("Scripts", required: false)
