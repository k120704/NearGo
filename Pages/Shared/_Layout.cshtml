<!DOCTYPE html>
<html lang="vi" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NearGo</title>
    <meta name="description" content="NearGo - Nền tảng thương mại điện tử bán sản phẩm cận date dành cho siêu thị tại Việt Nam" />
    <link rel="icon" type="image/svg+xml" href="/icons/favicon.svg" />

    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/flowbite@3.1.2/dist/flowbite.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <link rel="stylesheet" href="/css/site.css" asp-append-version="true" />

    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        primary: { 50: '#f0f9ff', 100: '#e0f2fe', 200: '#bae6fd', 300: '#7dd3fc', 400: '#38bdf8', 500: '#0ea5e9', 600: '#0284c7', 700: '#0369a1', 800: '#075985', 900: '#0c4a6e', 950: '#082f49' },
                        accent: { 50: '#fff7ed', 100: '#ffedd5', 200: '#fed7aa', 300: '#fdba74', 400: '#fb923c', 500: '#f97316', 600: '#ea580c', 700: '#c2410c', 800: '#9a3412', 900: '#7c2d12' },
                        success: { 50: '#f0fdf4', 500: '#22c55e', 600: '#16a34a' },
                        danger: { 50: '#fef2f2', 500: '#ef4444', 600: '#dc2626' },
                        warning: { 50: '#fffbeb', 500: '#f59e0b', 600: '#d97706' },
                    },
                    fontFamily: { sans: ['Inter', 'system-ui', 'sans-serif'] },
                    animation: {
                        'fade-in': 'fadeIn 0.5s ease-out',
                        'slide-up': 'slideUp 0.5s ease-out',
                        'slide-down': 'slideDown 0.3s ease-out',
                        'scale-in': 'scaleIn 0.2s ease-out',
                        'pulse-slow': 'pulse 3s cubic-bezier(0.4, 0, 0.6, 1) infinite',
                    },
                    keyframes: {
                        fadeIn: { '0%': { opacity: '0' }, '100%': { opacity: '1' } },
                        slideUp: { '0%': { transform: 'translateY(20px)', opacity: '0' }, '100%': { transform: 'translateY(0)', opacity: '1' } },
                        slideDown: { '0%': { transform: 'translateY(-10px)', opacity: '0' }, '100%': { transform: 'translateY(0)', opacity: '1' } },
                        scaleIn: { '0%': { transform: 'scale(0.9)', opacity: '0' }, '100%': { transform: 'scale(1)', opacity: '1' } },
                    }
                }
            }
        }
    </script>

    @{
        var gaMeasurementId = Context.RequestServices.GetRequiredService<Microsoft.Extensions.Configuration.IConfiguration>().GetSection("GoogleAnalytics")["MeasurementId"] ?? "";
        gaMeasurementId = System.Text.RegularExpressions.Regex.Replace(gaMeasurementId, @"[^G\d-]", "");
    }
    @if (!string.IsNullOrEmpty(gaMeasurementId) && gaMeasurementId.StartsWith("G-"))
    {
        <script async src="https://www.googletagmanager.com/gtag/js?id=@gaMeasurementId"></script>
        <script>
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());
            gtag('config', '@gaMeasurementId');
        </script>
    }
</head>
<body class="bg-gray-50 text-gray-900 antialiased">
    <div x-data="{ cartCount: 0, unreadCount: 0, notifList: [], notifOpen: false, isDark: localStorage.getItem('theme') === 'dark' }" x-init="
        if (isDark) document.documentElement.classList.add('dark');
        fetch('/cart/cartapi?handler=count').then(r => r.text()).then(c => cartCount = parseInt(c) || 0);
        loadNotifications();
        initSignalR();
    " class="min-h-screen flex flex-col">
        <header class="bg-white dark:bg-gray-900 shadow-sm border-b border-gray-100 dark:border-gray-800 sticky top-0 z-50">
            <nav class="max-w-7xl mx-auto px-4">
                <div class="flex items-center justify-between h-16">
                    <div class="flex items-center gap-8">
                        <a href="/" class="flex items-center gap-2 group">
                            <div class="w-9 h-9 bg-primary-700 rounded-xl flex items-center justify-center shadow-lg group-hover:shadow-xl transition-shadow">
                                <span class="text-white font-bold text-sm">N</span>
                            </div>
                            <span class="text-xl font-bold text-gray-900 dark:text-white">NearGo</span>
                        </a>
                        <div class="hidden lg:flex items-center gap-1">
                            <a href="/" class="px-4 py-2 text-sm font-medium rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors @((Context.Request.Path == "/") ? "text-primary-600 bg-primary-50 dark:bg-primary-900/20" : "text-gray-600 dark:text-gray-300")">
                                <i class="fas fa-home mr-1.5"></i>Trang chủ
                            </a>
                            <a href="/products" class="px-4 py-2 text-sm font-medium rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors @(Context.Request.Path.StartsWithSegments("/products") ? "text-primary-600 bg-primary-50 dark:bg-primary-900/20" : "text-gray-600 dark:text-gray-300")">
                                <i class="fas fa-box mr-1.5"></i>Sản phẩm
                            </a>
                            <a href="/flashsales" class="px-4 py-2 text-sm font-medium rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors @(Context.Request.Path.StartsWithSegments("/flashsales") ? "text-primary-600 bg-primary-50 dark:bg-primary-900/20" : "text-gray-600 dark:text-gray-300")">
                                <i class="fas fa-bolt mr-1.5"></i>Flash Sale
                            </a>
                            <a href="/supermarkets" class="px-4 py-2 text-sm font-medium rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors @(Context.Request.Path.StartsWithSegments("/supermarkets") ? "text-primary-600 bg-primary-50 dark:bg-primary-900/20" : "text-gray-600 dark:text-gray-300")">
                                <i class="fas fa-store mr-1.5"></i>Siêu thị
                            </a>
                        </div>
                    </div>
                    <div class="flex items-center gap-2">
                        <div class="hidden sm:block relative">
                            <form action="/products" method="get" class="relative">
                                <input type="text" name="search" placeholder="Tìm sản phẩm..." class="w-48 lg:w-64 pl-10 pr-4 py-2 text-sm border border-gray-200 dark:border-gray-700 rounded-xl bg-gray-50 dark:bg-gray-800 focus:ring-2 focus:ring-primary-500 focus:border-transparent outline-none transition-all" />
                                <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm"></i>
                            </form>
                        </div>
                        <button @@click="isDark = !isDark; localStorage.setItem('theme', isDark ? 'dark' : 'light'); document.documentElement.classList.toggle('dark')" class="p-2.5 rounded-xl hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors text-gray-500 dark:text-gray-400" title="Dark mode">
                            <i :class="isDark ? 'fas fa-sun' : 'fas fa-moon'" class="text-lg"></i>
                        </button>
                        @if (SignInManager.IsSignedIn(User))
                        {
                            var user = await UserManager.GetUserAsync(User);
                            var cartCount = Context.Request.Path.StartsWithSegments("/cart") ? 0 : await CartService.GetCartCount(UserManager.GetUserId(User)!);
                            <a href="/cart" class="relative p-2.5 rounded-xl hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors text-gray-500 dark:text-gray-400">
                                <i class="fas fa-shopping-cart text-lg"></i>
                                <span class="absolute -top-1 -right-1 bg-accent-500 text-white text-[10px] font-bold px-1.5 py-0.5 rounded-full min-w-[18px] text-center" x-text="cartCount">0</span>
                            </a>
                            <div class="relative" x-data="{ open: false }">
                                <button @@click="open = !open; if(open) loadNotifications();" class="relative p-2.5 rounded-xl hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors text-gray-500 dark:text-gray-400" title="Thông báo">
                                    <i class="fas fa-bell text-lg"></i>
                                    <span x-show="unreadCount > 0" x-text="unreadCount" class="absolute -top-1 -right-1 bg-danger-500 text-white text-[10px] font-bold px-1.5 py-0.5 rounded-full min-w-[18px] text-center"></span>
                                </button>
                                <div x-show="open" @@click.outside="open = false" x-transition.duration.200ms class="absolute right-0 mt-2 w-80 bg-white dark:bg-gray-800 rounded-2xl shadow-xl border border-gray-100 dark:border-gray-700 z-50 max-h-96 flex flex-col">
                                    <div class="flex items-center justify-between px-4 py-3 border-b border-gray-100 dark:border-gray-700 shrink-0">
                                        <h3 class="text-sm font-semibold text-gray-900 dark:text-white">Thông báo</h3>
                                        <button @@click="fetch('/notifications?handler=MarkAllRead', {method:'post'}).then(r=>{loadNotifications()})" class="text-xs text-primary-500 hover:text-primary-600">Đánh dấu tất cả</button>
                                    </div>
                                    <div class="overflow-y-auto flex-1">
                                        <template x-for="n in notifList" :key="n.id">
                                            <a :href="n.relatedUrl || '#'" @@click="if(!n.isRead){fetch('/notifications?handler=MarkRead&id='+n.id,{method:'post'}); loadNotifications()}" class="flex items-start gap-3 px-4 py-3 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors border-b border-gray-50 dark:border-gray-700 last:border-0" :class="!n.isRead ? 'bg-primary-50 dark:bg-primary-900/10' : ''">
                                                <div class="w-8 h-8 rounded-lg bg-primary-100 dark:bg-primary-900/30 flex items-center justify-center text-primary-500 shrink-0">
                                                    <i class="fas fa-store text-xs"></i>
                                                </div>
                                                <div class="flex-1 min-w-0">
                                                    <p class="text-sm font-medium text-gray-900 dark:text-white truncate" x-text="n.title"></p>
                                                    <p class="text-xs text-gray-500 line-clamp-2" x-text="n.message"></p>
                                                    <p class="text-xs text-gray-400 mt-1" x-text="timeAgo(n.createdAt)"></p>
                                                </div>
                                                <template x-if="!n.isRead">
                                                    <span class="w-2 h-2 rounded-full bg-primary-500 shrink-0 mt-2"></span>
                                                </template>
                                            </a>
                                        </template>
                                        <div x-show="notifList.length === 0" class="py-8 text-center text-sm text-gray-400">
                                            <i class="fas fa-bell-slash text-2xl mb-2 block"></i>
                                            Không có thông báo
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="relative" x-data="{ open: false }">
                                <button @@click="open = !open" class="flex items-center gap-2 p-1.5 rounded-xl hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">
                                    <div class="w-8 h-8 bg-primary-600 rounded-lg flex items-center justify-center text-white text-sm font-bold">
                                        @(user?.FullName?.FirstOrDefault() ?? 'U')
                                    </div>
                                    <span class="hidden sm:block text-sm font-medium text-gray-700 dark:text-gray-200">@(user?.FullName?.Split(' ').LastOrDefault() ?? "User")</span>
                                    <i class="fas fa-chevron-down text-xs text-gray-400"></i>
                                </button>
                                <div x-show="open" @@click.outside="open = false" x-transition.duration.200ms class="absolute right-0 mt-2 w-56 bg-white dark:bg-gray-800 rounded-2xl shadow-xl border border-gray-100 dark:border-gray-700 py-2 z-50">
                                    <div class="px-4 py-3 border-b border-gray-100 dark:border-gray-700">
                                        <p class="text-sm font-semibold text-gray-900 dark:text-white">@user?.FullName</p>
                                        <p class="text-xs text-gray-500">@user?.Email</p>
                                    </div>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <a href="/admin/dashboard" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-700">
                                            <i class="fas fa-tachometer-alt w-5 text-primary-500"></i> Dashboard
                                        </a>
                                    }
                                    @if (User.IsInRole("Supermarket"))
                                    {
                                        <a href="/supermarket/dashboard" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-700">
                                            <i class="fas fa-tachometer-alt w-5 text-primary-500"></i> Dashboard
                                        </a>
                                    }
                                    @if (User.IsInRole("Customer"))
                                    {
                                        <a href="/customer/dashboard" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-700">
                                            <i class="fas fa-user w-5 text-primary-500"></i> Tài khoản
                                        </a>
                                        <a href="/customer/orders" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-700">
                                            <i class="fas fa-clipboard-list w-5 text-primary-500"></i> Đơn hàng
                                        </a>
                                        <a href="/wishlist" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-700">
                                            <i class="fas fa-heart w-5 text-danger-500"></i> Yêu thích
                                        </a>
                                    }
                                    <a asp-page="/Auth/ChangePassword" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-700">
                                        <i class="fas fa-lock w-5 text-gray-400"></i> Đổi mật khẩu
                                    </a>
                                    <hr class="my-1 border-gray-100 dark:border-gray-700" />
                                    <form asp-page="/Auth/Logout" method="post" class="block">
                                        <button type="submit" class="flex items-center gap-3 px-4 py-2.5 text-sm text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 w-full text-left">
                                            <i class="fas fa-sign-out-alt w-5"></i> Đăng xuất
                                        </button>
                                    </form>
                                </div>
                            </div>
                        }
                        else
                        {
                            <a href="/auth/login" class="px-4 py-2 text-sm font-medium text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 rounded-xl transition-colors">Đăng nhập</a>
                            <a href="/auth/register" class="px-5 py-2 text-sm font-medium bg-primary-600 text-white rounded-xl hover:bg-primary-700 shadow-md hover:shadow-lg transition-all">Đăng ký</a>
                        }
                        <button id="mobile-menu-toggle" class="lg:hidden p-2.5 rounded-xl hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors" onclick="document.getElementById('mobile-menu').classList.toggle('hidden')">
                            <i class="fas fa-bars text-lg text-gray-600 dark:text-gray-300"></i>
                        </button>
                    </div>
                </div>
                <div id="mobile-menu" class="hidden lg:hidden pb-4 border-t border-gray-100 dark:border-gray-800 pt-4">
                    <form action="/products" method="get" class="mb-3 sm:hidden">
                        <input type="text" name="search" placeholder="Tìm sản phẩm..." class="w-full pl-10 pr-4 py-2.5 text-sm border border-gray-200 dark:border-gray-700 rounded-xl bg-gray-50 dark:bg-gray-800 focus:ring-2 focus:ring-primary-500 outline-none" />
                    </form>
                    <div class="space-y-1">
                        <a href="/" class="flex items-center gap-3 px-3 py-2.5 text-sm font-medium rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800"><i class="fas fa-home w-5 text-primary-500"></i>Trang chủ</a>
                        <a href="/products" class="flex items-center gap-3 px-3 py-2.5 text-sm font-medium rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800"><i class="fas fa-box w-5 text-primary-500"></i>Sản phẩm</a>
                        <a href="/flashsales" class="flex items-center gap-3 px-3 py-2.5 text-sm font-medium rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800"><i class="fas fa-bolt w-5 text-accent-500"></i>Flash Sale</a>
                        <a href="/supermarkets" class="flex items-center gap-3 px-3 py-2.5 text-sm font-medium rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800"><i class="fas fa-store w-5 text-primary-500"></i>Siêu thị</a>
                    </div>
                </div>
            </nav>
        </header>

        <main class="flex-1">
            @RenderBody()
        </main>

        <footer class="bg-white dark:bg-gray-900 border-t border-gray-100 dark:border-gray-800">
            <div class="max-w-7xl mx-auto px-4 py-12">
                <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
                    <div>
                        <div class="flex items-center gap-2 mb-4">
                            <div class="w-8 h-8 bg-primary-700 rounded-xl flex items-center justify-center">
                                <span class="text-white font-bold text-xs">N</span>
                            </div>
                            <span class="text-lg font-bold text-gray-900 dark:text-white">NearGo</span>
                        </div>
                        <p class="text-sm text-gray-500 dark:text-gray-400">Nền tảng thương mại điện tử bán sản phẩm cận date dành cho siêu thị tại Việt Nam.</p>
                    </div>
                    <div>
                        <h4 class="font-semibold text-sm mb-3 text-gray-900 dark:text-white">Sản phẩm</h4>
                        <ul class="space-y-2">
                            <li><a href="/products" class="text-sm text-gray-500 dark:text-gray-400 hover:text-primary-600">Tất cả sản phẩm</a></li>
                            <li><a href="/flashsales" class="text-sm text-gray-500 dark:text-gray-400 hover:text-primary-600">Flash Sale</a></li>
                            <li><a href="/products?category=san-pham-organic" class="text-sm text-gray-500 dark:text-gray-400 hover:text-primary-600">Sản phẩm Organic</a></li>
                            <li><a href="/surprise-boxes" class="text-sm text-gray-500 dark:text-gray-400 hover:text-primary-600">Hộp bất ngờ</a></li>
                        </ul>
                    </div>
                    <div>
                        <h4 class="font-semibold text-sm mb-3 text-gray-900 dark:text-white">Hỗ trợ</h4>
                        <ul class="space-y-2">
                            <li><a href="#" class="text-sm text-gray-500 dark:text-gray-400 hover:text-primary-600">Trung tâm hỗ trợ</a></li>
                            <li><a href="#" class="text-sm text-gray-500 dark:text-gray-400 hover:text-primary-600">Chính sách đổi trả</a></li>
                            <li><a href="#" class="text-sm text-gray-500 dark:text-gray-400 hover:text-primary-600">Chính sách bảo mật</a></li>
                            <li><a href="#" class="text-sm text-gray-500 dark:text-gray-400 hover:text-primary-600">Điều khoản sử dụng</a></li>
                        </ul>
                    </div>
                    <div>
                        <h4 class="font-semibold text-sm mb-3 text-gray-900 dark:text-white">Liên hệ</h4>
                        <ul class="space-y-2 text-sm text-gray-500 dark:text-gray-400">
                            <li><i class="fas fa-envelope w-5 mr-1"></i>hello@neargo.vn</li>
                            <li><i class="fas fa-phone w-5 mr-1"></i>1900 1234 5678</li>
                            <li><i class="fas fa-map-marker-alt w-5 mr-1"></i>123 Nguyễn Huệ, Quận 1, TP.HCM</li>
                        </ul>
                    </div>
                </div>
                <div class="border-t border-gray-100 dark:border-gray-800 mt-8 pt-8 text-center">
                    <p class="text-sm text-gray-400">&copy; @DateTime.UtcNow.Year NearGo. Tất cả quyền được bảo lưu.</p>
                </div>
            </div>
        </footer>

        <partial name="_Chatbot" />
    </div>

    <script src="https://cdn.jsdelivr.net/npm/flowbite@3.1.2/dist/flowbite.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.8/dist/cdn.min.js" defer></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@@8.0.0/dist/browser/signalr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    <script src="/js/site.js" asp-append-version="true"></script>
    <script>
        AOS.init({ duration: 800, once: true });
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>
