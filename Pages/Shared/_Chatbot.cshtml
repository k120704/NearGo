<div x-data="chatbot()" x-init="init()" class="fixed bottom-6 right-6 z-50">
    <button @@click="toggle()" class="w-14 h-14 bg-gradient-to-r from-primary-500 to-primary-600 text-white rounded-full shadow-lg hover:shadow-xl hover:scale-105 transition-all flex items-center justify-center"
            :class="{ 'rotate-90': isOpen }">
        <i :class="isOpen ? 'fas fa-times text-xl' : 'fas fa-robot text-xl'"></i>
    </button>
    <div x-show="isOpen" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 scale-90 translate-y-4"
         x-transition:enter-end="opacity-100 scale-100 translate-y-0"
         class="absolute bottom-16 right-0 w-80 sm:w-96 bg-white dark:bg-gray-800 rounded-2xl shadow-2xl border border-gray-100 dark:border-gray-700 overflow-hidden">
        <div class="bg-gradient-to-r from-primary-500 to-primary-600 p-4">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-white/20 rounded-xl flex items-center justify-center">
                    <i class="fas fa-robot text-white text-lg"></i>
                </div>
                <div>
                    <h3 class="text-white font-semibold text-sm">NearGo Bot</h3>
                    <p class="text-white/70 text-xs">Tôi có thể giúp gì cho bạn?</p>
                </div>
            </div>
        </div>
        <div class="h-80 overflow-y-auto p-4 space-y-3" x-ref="messages" id="chat-messages">
            <template x-for="(msg, idx) in messages" :key="idx">
                <div :class="msg.role === 'user' ? 'flex justify-end' : 'flex justify-start'">
                    <div :class="msg.role === 'user' ? 'bg-primary-500 text-white rounded-2xl rounded-br-sm' : 'bg-gray-100 dark:bg-gray-700 text-gray-900 dark:text-white rounded-2xl rounded-bl-sm'"
                         class="max-w-[80%] px-4 py-2.5 text-sm">
                        <p x-html="msg.content"></p>
                    </div>
                </div>
            </template>
            <div x-show="loading" class="flex justify-start">
                <div class="bg-gray-100 dark:bg-gray-700 rounded-2xl rounded-bl-sm px-4 py-3">
                    <div class="flex gap-1">
                        <span class="w-2 h-2 bg-gray-400 rounded-full animate-bounce" style="animation-delay:0ms"></span>
                        <span class="w-2 h-2 bg-gray-400 rounded-full animate-bounce" style="animation-delay:150ms"></span>
                        <span class="w-2 h-2 bg-gray-400 rounded-full animate-bounce" style="animation-delay:300ms"></span>
                    </div>
                </div>
            </div>
        </div>
        <div class="border-t border-gray-100 dark:border-gray-700 p-3">
            <form @@submit.prevent="sendMessage()" class="flex gap-2">
                <input type="text" x-model="message" placeholder="Nhập tin nhắn..." class="flex-1 px-4 py-2.5 text-sm border border-gray-200 dark:border-gray-600 rounded-xl bg-gray-50 dark:bg-gray-700 focus:ring-2 focus:ring-primary-500 outline-none" />
                <button type="submit" class="px-4 py-2.5 bg-primary-500 text-white rounded-xl hover:bg-primary-600 transition-colors">
                    <i class="fas fa-paper-plane"></i>
                </button>
            </form>
            <div class="mt-2 flex gap-1.5 flex-wrap">
                <button @@click="quickReply('Có sản phẩm nào sắp hết hạn không?')" class="text-xs px-2.5 py-1 rounded-full bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 hover:bg-primary-50 hover:text-primary-600 transition-colors">Sản phẩm cận date</button>
                <button @@click="quickReply('Cách mua hàng như thế nào?')" class="text-xs px-2.5 py-1 rounded-full bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 hover:bg-primary-50 hover:text-primary-600 transition-colors">Hướng dẫn mua</button>
                <button @@click="quickReply('Chính sách đổi trả?')" class="text-xs px-2.5 py-1 rounded-full bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 hover:bg-primary-50 hover:text-primary-600 transition-colors">Đổi trả</button>
            </div>
        </div>
    </div>
</div>
<script>
    function chatbot() {
        return {
            isOpen: false,
            message: '',
            loading: false,
            messages: [
                { role: 'assistant', content: 'Xin chào! Tôi là trợ lý NearGo. Tôi có thể giúp bạn tìm kiếm sản phẩm, giải đáp thắc mắc về thực phẩm cận date. Bạn cần tôi giúp gì?' }
            ],
            toggle() { this.isOpen = !this.isOpen; },
            async sendMessage() {
                if (!this.message.trim() || this.loading) return;
                const userMsg = this.message;
                this.messages.push({ role: 'user', content: this.message });
                this.message = '';
                this.loading = true;
                this.scrollToBottom();
                try {
                    const resp = await fetch('/chatbot/send', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ message: userMsg })
                    });
                    const data = await resp.json();
                    this.messages.push({ role: 'assistant', content: data.response });
                } catch {
                    this.messages.push({ role: 'assistant', content: 'Xin lỗi, tôi đang gặp sự cố kết nối. Vui lòng thử lại sau.' });
                }
                this.loading = false;
                this.scrollToBottom();
            },
            quickReply(text) {
                this.message = text;
                this.sendMessage();
            },
            scrollToBottom() {
                setTimeout(() => {
                    const el = this.$refs.messages;
                    if (el) el.scrollTop = el.scrollHeight;
                }, 50);
            },
            init() {}
        }
    }
</script>
