<div x-data="chatbot()" x-init="init()" class="fixed bottom-6 right-6 z-50">
    <button @@click="toggle(); save()" class="w-14 h-14 bg-primary-600 text-white rounded-full shadow-lg hover:shadow-xl hover:scale-105 transition-all flex items-center justify-center"
            :class="{ 'rotate-90': isOpen }">
        <i :class="isOpen ? 'fas fa-times text-xl' : 'fas fa-robot text-xl'"></i>
    </button>
    <div x-show="isOpen" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 scale-90 translate-y-4"
         x-transition:enter-end="opacity-100 scale-100 translate-y-0"
         class="absolute bottom-16 right-0 w-80 sm:w-96 bg-white dark:bg-gray-800 rounded-2xl shadow-2xl border border-gray-100 dark:border-gray-700 overflow-hidden">
        <div class="bg-primary-600 p-4">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-white/20 rounded-xl flex items-center justify-center">
                    <i class="fas fa-robot text-white text-lg"></i>
                </div>
                <div class="flex-1">
                    <h3 class="text-white font-semibold text-sm">NearGo Bot</h3>
                    <p class="text-white/70 text-xs">Tôi có thể giúp gì cho bạn?</p>
                </div>
                <button @@click="clearHistory()" class="text-white/60 hover:text-white transition-colors text-xs" title="Xóa lịch sử">
                    <i class="fas fa-trash-alt"></i>
                </button>
            </div>
        </div>
        <div class="h-80 overflow-y-auto p-4 space-y-3" x-ref="messages" id="chat-messages">
            <template x-for="(msg, idx) in messages" :key="idx">
                <div>
                    <div :class="msg.role === 'user' ? 'flex justify-end' : 'flex justify-start'">
                        <div :class="msg.role === 'user' ? 'bg-primary-500 text-white rounded-2xl rounded-br-sm' : 'bg-gray-100 dark:bg-gray-700 text-gray-900 dark:text-white rounded-2xl rounded-bl-sm'"
                             class="max-w-[80%] px-4 py-2.5 text-sm">
                            <p x-html="msg.content"></p>
                        </div>
                    </div>
                    <template x-if="msg.products && msg.products.length">
                        <div class="flex gap-2 mt-2 overflow-x-auto pb-1">
                            <template x-for="(p, pidx) in msg.products" :key="pidx">
                                <a :href="'/products/detail?id=' + p.id" class="shrink-0 w-36 bg-white dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-xl overflow-hidden hover:shadow-md transition-shadow">
                                    <div class="h-24 bg-gray-100 dark:bg-gray-600 flex items-center justify-center overflow-hidden">
                                        <img :src="p.image || '/icons/favicon.svg'" :alt="p.name" class="w-full h-full object-cover" onerror="this.src='/icons/favicon.svg'" />
                                    </div>
                                    <div class="p-2">
                                        <p class="text-xs font-semibold text-gray-900 dark:text-white truncate" x-text="p.name"></p>
                                        <p class="text-sm font-bold text-primary-600" x-text="p.price.toLocaleString() + 'đ'"></p>
                                        <p class="text-xs text-gray-400 line-through" x-show="p.originalPrice > p.price" x-text="p.originalPrice.toLocaleString() + 'đ'"></p>
                                    </div>
                                </a>
                            </template>
                        </div>
                    </template>
                    <template x-if="msg.supermarkets && msg.supermarkets.length">
                        <div class="flex gap-2 mt-2 overflow-x-auto pb-1">
                            <template x-for="(s, sidx) in msg.supermarkets" :key="sidx">
                                <a :href="'/supermarkets/detail?slug=' + s.slug" class="shrink-0 w-36 bg-white dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-xl overflow-hidden hover:shadow-md transition-shadow">
                                    <div class="h-16 bg-gray-100 dark:bg-gray-600 flex items-center justify-center">
                                        <img :src="s.logo || '/icons/favicon.svg'" :alt="s.name" class="h-10 w-10 object-contain" onerror="this.src='/icons/favicon.svg'" />
                                    </div>
                                    <div class="p-2">
                                        <p class="text-xs font-semibold text-gray-900 dark:text-white truncate" x-text="s.name"></p>
                                        <p class="text-xs text-gray-500 truncate" x-text="s.address || ''"></p>
                                        <p class="text-xs text-yellow-500" x-show="s.rating"><i class="fas fa-star mr-0.5"></i><span x-text="Number(s.rating).toFixed(1)"></span></p>
                                    </div>
                                </a>
                            </template>
                        </div>
                    </template>
                </div>
            </template>
            <div x-show="loading" class="flex justify-start">
                <div class="bg-gray-100 dark:bg-gray-700 rounded-2xl rounded-bl-sm px-4 py-3">
                    <div class="flex gap-1">
                        <span class="w-2 h-2 bg-gray-400 rounded-full animate-bounce" style="animation-delay:0ms"></span>
                        <span class="w-2 h-2 bg-gray-400 rounded-full animate-bounce" style="animation-delay:150ms"></span>
                        <span class="w-2 h-2 bg-gray-400 rounded-full animate-bounce" style="animation-delay:300ms"></span>
                    </div>
                </div>
            </div>
        </div>
        <div class="border-t border-gray-100 dark:border-gray-700 p-3">
            <form @@submit.prevent="sendMessage()" class="flex gap-2">
                <input type="text" x-model="message" @@keydown.enter.prevent="sendMessage()" placeholder="Nhập tin nhắn..." class="flex-1 px-4 py-2.5 text-sm border border-gray-200 dark:border-gray-600 rounded-xl bg-gray-50 dark:bg-gray-700 focus:ring-2 focus:ring-primary-500 outline-none" />
                <button type="button" @@click="sendMessage()" class="px-4 py-2.5 bg-primary-500 text-white rounded-xl hover:bg-primary-600 transition-colors">
                    <i class="fas fa-paper-plane"></i>
                </button>
            </form>
            <div class="mt-2 flex gap-1.5 flex-wrap">
                <button @@click="quickReply('Có sản phẩm nào sắp hết hạn không?')" class="text-xs px-2.5 py-1 rounded-full bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 hover:bg-primary-50 hover:text-primary-600 transition-colors">Sản phẩm cận date</button>
                <button @@click="quickReply('Cách mua hàng như thế nào?')" class="text-xs px-2.5 py-1 rounded-full bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 hover:bg-primary-50 hover:text-primary-600 transition-colors">Hướng dẫn mua</button>
                <button @@click="quickReply('Chính sách đổi trả?')" class="text-xs px-2.5 py-1 rounded-full bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 hover:bg-primary-50 hover:text-primary-600 transition-colors">Đổi trả</button>
            </div>
        </div>
    </div>
</div>
<script>
    function chatbot() {
        return {
            isOpen: localStorage.getItem('cb_open') === 'true',
            message: '',
            loading: false,
            messages: JSON.parse(localStorage.getItem('cb_msgs') || 'null') || [
                { role: 'assistant', content: 'Xin chào! Tôi là trợ lý NearGo. Tôi có thể giúp bạn tìm kiếm sản phẩm, giải đáp thắc mắc về thực phẩm cận date. Bạn cần tôi giúp gì?' }
            ],
            save() {
                localStorage.setItem('cb_msgs', JSON.stringify(this.messages));
                localStorage.setItem('cb_open', this.isOpen);
            },
            toggle() { this.isOpen = !this.isOpen; },
            clearHistory() {
                this.messages = [{ role: 'assistant', content: 'Xin chào! Tôi là trợ lý NearGo. Tôi có thể giúp bạn tìm kiếm sản phẩm, giải đáp thắc mắc về thực phẩm cận date. Bạn cần tôi giúp gì?' }];
                this.save();
            },
            async sendMessage() {
                if (!this.message.trim() || this.loading) return;
                const userMsg = this.message;
                this.messages.push({ role: 'user', content: this.message });
                this.message = '';
                this.loading = true;
                this.scrollToBottom();
                this.save();
                try {
                    const resp = await fetch('/chatbot/send', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ message: userMsg })
                    });
                    const data = await resp.json();
                    const m = { role: 'assistant', content: data.response };
                    if (data.products && data.products.length) m.products = data.products;
                    if (data.supermarkets && data.supermarkets.length) m.supermarkets = data.supermarkets;
                    this.messages.push(m);
                } catch {
                    this.messages.push({ role: 'assistant', content: 'Xin lỗi, tôi đang gặp sự cố kết nối. Vui lòng thử lại sau.' });
                }
                this.loading = false;
                this.scrollToBottom();
                this.save();
            },
            quickReply(text) {
                this.message = text;
                this.sendMessage();
            },
            scrollToBottom() {
                setTimeout(() => {
                    const el = this.$refs.messages;
                    if (el) el.scrollTop = el.scrollHeight;
                }, 50);
            },
            init() {
                this.scrollToBottom();
            }
        }
    }
</script>
