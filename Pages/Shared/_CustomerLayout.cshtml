@{
    Layout = "_Layout";
}
<div class="max-w-7xl mx-auto px-4 py-6 grid grid-cols-1 md:grid-cols-4 gap-6">
    <aside class="md:col-span-1">
        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 overflow-hidden sticky top-20">
            <div class="p-4 bg-gradient-to-r from-primary-500 to-primary-600 text-white text-center">
                @{
                    var user = await UserManager.GetUserAsync(User);
                }
                <div class="w-14 h-14 bg-white/20 rounded-xl flex items-center justify-center mx-auto mb-2">
                    <span class="text-2xl font-bold">@(user?.FullName?.FirstOrDefault() ?? 'U')</span>
                </div>
                <p class="font-semibold text-sm">@user?.FullName</p>
                <p class="text-white/60 text-xs">@user?.Email</p>
            </div>
            <nav class="p-2 space-y-1">
                <a href="/customer/dashboard" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm @(Context.Request.Path == "/customer/dashboard" ? "bg-primary-50 dark:bg-primary-900/20 text-primary-600 font-medium" : "text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700")">
                    <i class="fas fa-th-large w-5"></i> Tổng quan
                </a>
                <a href="/customer/orders" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm @(Context.Request.Path.StartsWithSegments("/customer/orders") ? "bg-primary-50 dark:bg-primary-900/20 text-primary-600 font-medium" : "text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700")">
                    <i class="fas fa-clipboard-list w-5"></i> Đơn hàng
                </a>
                <a href="/customer/profile" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm @(Context.Request.Path == "/customer/profile" ? "bg-primary-50 dark:bg-primary-900/20 text-primary-600 font-medium" : "text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700")">
                    <i class="fas fa-user w-5"></i> Hồ sơ
                </a>
                <a href="/wishlist" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm @(Context.Request.Path == "/wishlist" ? "bg-primary-50 dark:bg-primary-900/20 text-primary-600 font-medium" : "text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700")">
                    <i class="fas fa-heart w-5 text-red-500"></i> Yêu thích
                </a>
                <hr class="border-gray-100 dark:border-gray-700 my-2" />
                <a href="/auth/change-password" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700">
                    <i class="fas fa-lock w-5"></i> Đổi mật khẩu
                </a>
            </nav>
        </div>
    </aside>
    <main class="md:col-span-3">
        @RenderBody()
    </main>
</div>
