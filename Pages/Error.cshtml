@page
@{
    ViewData["Title"] = "Lỗi";
    Layout = "_AuthLayout";
}
<div class="min-h-screen flex items-center justify-center bg-gray-50 dark:bg-gray-900 px-4">
    <div class="text-center">
        <div class="w-24 h-24 bg-red-100 dark:bg-red-900/30 rounded-full flex items-center justify-center mx-auto mb-6">
            <i class="fas fa-exclamation-triangle text-4xl text-red-500"></i>
        </div>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">Đã xảy ra lỗi</h1>
        <p class="text-gray-500 dark:text-gray-400 mb-6">Vui lòng thử lại sau</p>
        <a href="/" class="inline-flex items-center gap-2 px-6 py-3 bg-primary-500 text-white rounded-xl hover:bg-primary-600">Về trang chủ</a>
    </div>
</div>
