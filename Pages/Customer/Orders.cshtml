@page
@model NearGo.Pages.Customer.OrdersModel
@{
    ViewData["Title"] = "Đơn hàng của tôi";
    Layout = "_CustomerLayout";
}
<div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 p-6">
    <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Đơn hàng của tôi</h2>
    @if (!Model.Orders.Any())
    {
        <div class="text-center py-8">
            <p class="text-sm text-gray-400">Chưa có đơn hàng nào</p>
            <a href="/products" class="mt-2 inline-block text-primary-500 text-sm hover:text-primary-600">Mua sắm ngay</a>
        </div>
    }
    else
    {
        <div class="space-y-3">
            @foreach (var order in Model.Orders)
            {
                <div class="border border-gray-100 dark:border-gray-700 rounded-xl overflow-hidden">
                    <div class="flex items-center justify-between p-4 bg-gray-50 dark:bg-gray-800/50">
                        <div>
                            <span class="text-sm font-semibold text-gray-900 dark:text-white">#@order.OrderCode</span>
                            <span class="text-xs text-gray-500 ml-2">@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</span>
                        </div>
                        <div class="flex items-center gap-3">
                            <span class="text-xs px-2 py-0.5 rounded-full font-medium @(order.Status == "Delivered" ? "bg-green-100 text-green-600" : order.Status == "Cancelled" ? "bg-red-100 text-red-600" : "bg-yellow-100 text-yellow-600")">
                                @(order.Status == "Pending" ? "Chờ xác nhận" : order.Status == "Confirmed" ? "Đã xác nhận" : order.Status == "Shipping" ? "Đang giao" : order.Status == "Delivered" ? "Đã giao" : "Đã hủy")
                            </span>
                            <a href="/customer/orders/detail?id=@order.Id" class="text-primary-500 text-sm hover:text-primary-600">
                                <i class="fas fa-eye"></i>
                            </a>
                        </div>
                    </div>
                    <div class="p-4">
                        @foreach (var item in order.OrderItems.Take(3))
                        {
                            <div class="flex items-center gap-3 mb-2 last:mb-0">
                                <img src="@item.Product.ImageUrl" alt="@item.Product.Name" class="w-10 h-10 rounded-lg object-cover" />
                                <div class="flex-1 min-w-0">
                                    <p class="text-sm text-gray-900 dark:text-white truncate">@item.Product.Name</p>
                                    <p class="text-xs text-gray-400">x@(item.Quantity) - @item.UnitPrice.ToString("N0")đ</p>
                                </div>
                            </div>
                        }
                        @if (order.OrderItems.Count > 3)
                        {
                            <p class="text-xs text-gray-400 mt-1">...và @(order.OrderItems.Count - 3) sản phẩm khác</p>
                        }
                    </div>
                    <div class="flex items-center justify-between px-4 py-3 bg-gray-50 dark:bg-gray-800/50 border-t border-gray-100 dark:border-gray-700">
                        <span class="text-sm text-gray-500">Tổng: <strong class="text-gray-900 dark:text-white">@order.TotalAmount.ToString("N0")đ</strong></span>
                        <span class="text-xs text-gray-400">@order.Supermarket?.Name</span>
                    </div>
                </div>
            }
        </div>
    }
</div>
