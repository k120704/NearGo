@page
@model NearGo.Pages.Customer.DashboardModel
@{
    ViewData["Title"] = "Tài khoản";
    Layout = "_CustomerLayout";
}
<div class="space-y-6">
    <div class="bg-primary-600 rounded-2xl p-6 text-white">
        <h2 class="text-xl font-bold">Xin chào, @Model.UserProfile?.FullName!</h2>
        <p class="text-white/70 text-sm mt-1">Chào mừng bạn đến với NearGo</p>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="bg-white dark:bg-gray-800 rounded-2xl p-4 shadow-sm border border-gray-100 dark:border-gray-700">
            <div class="w-10 h-10 bg-primary-50 dark:bg-primary-900/20 rounded-xl flex items-center justify-center mb-3">
                <i class="fas fa-shopping-bag text-primary-500"></i>
            </div>
            <p class="text-2xl font-bold text-gray-900 dark:text-white">@Model.TotalOrders</p>
            <p class="text-xs text-gray-500">Đơn hàng</p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-2xl p-4 shadow-sm border border-gray-100 dark:border-gray-700">
            <div class="w-10 h-10 bg-green-50 dark:bg-green-900/20 rounded-xl flex items-center justify-center mb-3">
                <i class="fas fa-check text-green-500"></i>
            </div>
            <p class="text-2xl font-bold text-gray-900 dark:text-white">@Model.CompletedOrders</p>
            <p class="text-xs text-gray-500">Hoàn thành</p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-2xl p-4 shadow-sm border border-gray-100 dark:border-gray-700">
            <div class="w-10 h-10 bg-accent-50 dark:bg-accent-900/20 rounded-xl flex items-center justify-center mb-3">
                <i class="fas fa-star text-accent-500"></i>
            </div>
            <p class="text-2xl font-bold text-gray-900 dark:text-white">@Model.WishlistCount</p>
            <p class="text-xs text-gray-500">Yêu thích</p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-2xl p-4 shadow-sm border border-gray-100 dark:border-gray-700">
            <div class="w-10 h-10 bg-purple-50 dark:bg-purple-900/20 rounded-xl flex items-center justify-center mb-3">
                <i class="fas fa-coins text-purple-500"></i>
            </div>
            <p class="text-2xl font-bold text-gray-900 dark:text-white">@Model.LoyaltyPoints</p>
            <p class="text-xs text-gray-500">Điểm thưởng</p>
        </div>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 p-6">
        <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Đơn hàng gần đây</h3>
        @if (Model.RecentOrders.Any())
        {
            <div class="space-y-3">
                @foreach (var order in Model.RecentOrders)
                {
                    <a href="/customer/orders/detail?id=@order.Id" class="flex items-center justify-between p-4 bg-gray-50 dark:bg-gray-700/50 rounded-xl hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
                        <div>
                            <p class="text-sm font-semibold text-gray-900 dark:text-white">#@order.OrderCode</p>
                            <p class="text-xs text-gray-500">@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
                        </div>
                        <div class="text-right">
                            <p class="text-sm font-bold text-gray-900 dark:text-white">@order.TotalAmount.ToString("N0")đ</p>
                            <span class="text-xs px-2 py-0.5 rounded-full @(order.Status == "Delivered" ? "bg-green-100 text-green-600" : order.Status == "Pending" ? "bg-yellow-100 text-yellow-600" : "bg-blue-100 text-blue-600")">
                                @order.Status
                            </span>
                        </div>
                    </a>
                }
            </div>
        }
        else
        {
            <p class="text-sm text-gray-400 text-center py-4">Chưa có đơn hàng nào</p>
        }
    </div>
</div>
