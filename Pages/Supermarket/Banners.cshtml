@page
@model NearGo.Pages.Supermarket.BannersModel
@{
    ViewData["Title"] = "Quảng cáo Banner";
    Layout = "_SupermarketLayout";
}
<div class="space-y-6">

    @* Gói đăng ký banner *@
    <div class="bg-gradient-to-r from-primary-500 via-primary-600 to-accent-500 rounded-2xl p-6 shadow-md text-white">
        <div class="flex items-center justify-between flex-wrap gap-4">
            <div>
                <h2 class="text-lg font-semibold">Gói quảng cáo Banner</h2>
                <p class="text-white/70 text-sm mt-1">Hiển thị trên trang chủ NearGo trong 30 ngày</p>
                <ul class="text-white/60 text-xs mt-2 space-y-1">
                    <li><i class="fas fa-check mr-1 text-green-300"></i> Vị trí banner trang chủ</li>
                    <li><i class="fas fa-check mr-1 text-green-300"></i> Kích thước 1920x600px</li>
                    <li><i class="fas fa-check mr-1 text-green-300"></i> Kèm link đến sản phẩm</li>
                </ul>
            </div>
            <div class="text-right">
                <p class="text-3xl font-bold">Từ 50,000đ</p>
                <p class="text-xs text-white/60 mt-1">Gói 7, 15, 30 ngày</p>
                <form method="post" class="mt-2">
                    <button type="submit" class="px-6 py-3 bg-white text-primary-600 font-semibold rounded-xl hover:bg-gray-100 transition-all shadow-lg">
                        <i class="fas fa-credit-card mr-1"></i> Đăng ký ngay
                    </button>
                </form>
            </div>
        </div>
    </div>

    @* Danh sách banner đã đăng ký *@
    <div class="bg-white dark:bg-gray-800 rounded-2xl p-6 shadow-sm border border-gray-100 dark:border-gray-700">
        <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Banner của tôi (@Model.Banners.Count)</h3>
        @if (!Model.Banners.Any())
        {
            <p class="text-gray-400 text-sm py-8 text-center">Chưa đăng ký banner nào. Bấm "Đăng ký ngay" phía trên để bắt đầu.</p>
        }
        <div class="space-y-3">
            @foreach (var b in Model.Banners)
            {
                <div class="flex items-center gap-4 p-3 border border-gray-100 dark:border-gray-700 rounded-xl">
                    <img src="@b.ImageUrl" alt="@b.Title" class="w-24 h-14 object-cover rounded-lg flex-shrink-0" />
                    <div class="flex-1 min-w-0">
                        <p class="text-sm font-medium text-gray-900 dark:text-white truncate">@b.Title</p>
                        <p class="text-xs text-gray-400">
                            @b.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                            @if (b.PackageDays > 0) {
                                <span class="ml-2 px-1.5 py-0.5 bg-primary-50 dark:bg-primary-900/20 text-primary-500 rounded text-[10px] font-medium">@b.PackageDays ngày - @b.PackagePrice.ToString("N0")đ</span>
                            }
                        </p>
                    </div>
                    <div class="flex items-center gap-2 flex-shrink-0">
                        @if (b.Status == "Draft" && b.PaymentStatus == "Unpaid")
                        {
                            <span class="px-2 py-0.5 rounded-full text-xs bg-gray-100 text-gray-500 font-medium">Chưa TT</span>
                            <a href="/supermarket/banners/payment?id=@b.Id" class="px-3 py-1.5 bg-primary-500 text-white text-xs font-medium rounded-lg hover:bg-primary-600 transition-colors">
                                <i class="fas fa-credit-card mr-1"></i> Thanh toán ngay
                            </a>
                            <form method="post" asp-page-handler="Delete" class="inline" onsubmit="return confirm('Xóa banner này?')">
                                <input type="hidden" name="id" value="@b.Id" />
                                <button type="submit" class="px-2 py-1.5 text-xs text-red-500 border border-red-200 rounded-lg hover:bg-red-50 transition-colors">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        }
                        else if (b.Status == "Pending")
                        {
                            <span class="px-2 py-0.5 rounded-full text-xs bg-green-100 text-green-600 font-medium">Đã TT</span>
                            <span class="px-2 py-0.5 rounded-full text-xs bg-yellow-100 text-yellow-600 font-medium">Chờ duyệt</span>
                        }
                        else if (b.Status == "Approved")
                        {
                            <span class="px-2 py-0.5 rounded-full text-xs bg-green-100 text-green-600 font-medium">Đang hiển thị</span>
                        }
                        else if (b.Status == "Rejected")
                        {
                            <span class="px-2 py-0.5 rounded-full text-xs bg-red-100 text-red-600 font-medium">Bị từ chối</span>
                            if (!string.IsNullOrEmpty(b.AdminNote))
                            {
                                <span class="text-xs text-gray-400 max-w-[120px] truncate" title="@b.AdminNote">@b.AdminNote</span>
                            }
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>
