@page
@model NearGo.Pages.Payment.SEPayReturnModel
@{
    ViewData["Title"] = "Thanh toán qua SEPay";
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 flex items-center justify-center min-h-screen">
    <div class="max-w-lg w-full mx-4">
        <div class="bg-white rounded-3xl shadow-xl p-8 text-center">
            <div class="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <i class="fas fa-qrcode text-3xl text-blue-500"></i>
            </div>
            <h1 class="text-xl font-bold text-gray-900 mb-2">Quét mã để thanh toán</h1>
            <p class="text-gray-500 mb-6">Vui lòng chuyển khoản đúng nội dung bên dưới</p>

            <div class="bg-gray-50 rounded-2xl p-6 mb-6">
                <img src="@Model.QRUrl" alt="QR thanh toán" class="w-48 h-48 mx-auto mb-4" />
                <p class="text-xs text-gray-400 mb-2">Hoặc chuyển khoản tới</p>
                <div class="space-y-2 text-sm text-left">
                    <div class="flex justify-between">
                        <span class="text-gray-500">Ngân hàng</span>
                        <span class="font-medium text-gray-900">@Model.BankName</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-gray-500">Số tài khoản</span>
                        <span class="font-medium text-gray-900">@Model.BankAccount</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-gray-500">Chủ tài khoản</span>
                        <span class="font-medium text-gray-900">@Model.AccountHolder</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-gray-500">Số tiền</span>
                        <span class="font-medium text-red-500">@Model.Amount.ToString("N0")đ</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-gray-500">Nội dung</span>
                        <span class="font-medium text-primary-600 bg-primary-50 px-2 py-0.5 rounded">@Model.TransferContent</span>
                    </div>
                </div>
            </div>

            <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-4 mb-6 text-left">
                <p class="text-xs text-yellow-700">
                    <i class="fas fa-info-circle mr-1"></i>
                    <strong>Lưu ý:</strong> Nội dung chuyển khoản phải bắt đầu bằng <strong>SEVQR</strong> và có chứa <strong>TKP@Model.OrderCode</strong> để hệ thống xác nhận tự động.
                </p>
            </div>

            <a href="/customer/orders" class="inline-block w-full px-6 py-3 bg-primary-500 text-white rounded-xl hover:bg-primary-600 transition-colors">
                <i class="fas fa-clipboard-list mr-2"></i>Xem đơn hàng
            </a>
        </div>
    </div>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <script>
        const orderCode = '@Model.OrderCode';
        async function checkPayment() {
            try {
                const resp = await fetch('/api/payment/status/' + orderCode);
                const data = await resp.json();
                if (data.paid) {
                    window.location.href = '/customer/orders';
                }
            } catch (e) {}
        }
        setInterval(checkPayment, 5000);
        checkPayment();
    </script>
</body>
</html>
