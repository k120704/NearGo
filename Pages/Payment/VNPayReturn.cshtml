@page
@model NearGo.Pages.Payment.VNPayReturnModel
@{
    ViewData["Title"] = "Kết quả thanh toán VNPay";
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 flex items-center justify-center min-h-screen">
    <div class="max-w-md w-full mx-4 text-center">
        <div class="bg-white rounded-3xl shadow-xl p-8">
            @if (Model.IsSuccess)
            {
                <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
                    <i class="fas fa-check-circle text-3xl text-green-500"></i>
                </div>
                <h1 class="text-xl font-bold text-gray-900 mb-2">Thanh toán thành công</h1>
                <p class="text-gray-500 mb-6">Mã giao dịch: @Model.TransactionId</p>
            }
            else
            {
                <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
                    <i class="fas fa-times-circle text-3xl text-red-500"></i>
                </div>
                <h1 class="text-xl font-bold text-gray-900 mb-2">Thanh toán thất bại</h1>
                <p class="text-gray-500 mb-6">@Model.ErrorMessage</p>
            }
            @if (Model.IsBannerPayment)
            {
                <a href="/supermarket/banners" class="inline-block px-6 py-3 bg-primary-500 text-white rounded-xl hover:bg-primary-600 transition-colors">
                    <i class="fas fa-images mr-2"></i>Về Banner
                </a>
            }
            else if (Model.IsSubscriptionPayment)
            {
                <a href="/supermarket/dashboard" class="inline-block px-6 py-3 bg-primary-500 text-white rounded-xl hover:bg-primary-600 transition-colors">
                    <i class="fas fa-store mr-2"></i>Về Dashboard
                </a>
            }
            else
            {
                <a href="/customer/orders" class="inline-block px-6 py-3 bg-primary-500 text-white rounded-xl hover:bg-primary-600 transition-colors">
                    <i class="fas fa-clipboard-list mr-2"></i>Xem đơn hàng
                </a>
            }
        </div>
    </div>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
</body>
</html>
