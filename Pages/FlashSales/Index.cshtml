@page
@model NearGo.Pages.FlashSales.IndexModel
@{
    ViewData["Title"] = "Flash Sale";
}
<div class="max-w-7xl mx-auto px-4 py-6">
    <div class="bg-gradient-to-r from-red-500 via-red-600 to-accent-500 rounded-2xl p-8 mb-6 text-white text-center">
        <i class="fas fa-bolt text-5xl mb-4"></i>
        <h1 class="text-3xl font-bold mb-2">Flash Sale</h1>
        <p class="text-white/80">Sản phẩm giảm giá sốc trong thời gian có hạn</p>
    </div>
    @if (Model.FlashSaleProducts.Any())
    {
        <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-4">
            @foreach (var fp in Model.FlashSaleProducts)
            {
                <div class="bg-white dark:bg-gray-800 rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-all group border border-gray-100 dark:border-gray-700">
                    <div class="relative overflow-hidden">
                        <a href="/products/detail?id=@fp.Product.Id">
                            <img src="@fp.Product.ImageUrl" alt="@fp.Product.Name" class="w-full h-40 object-cover group-hover:scale-105 transition-transform" loading="lazy" />
                        </a>
                        <span class="absolute top-2 left-2 bg-red-500 text-white text-xs font-bold px-2 py-0.5 rounded-lg">
                            -@((int)((1 - fp.SalePrice / fp.Product.OriginalPrice) * 100))%
                        </span>
                        <div class="absolute bottom-0 inset-x-0 bg-gradient-to-t from-black/60 to-transparent p-2">
                            <div class="bg-white/20 rounded-full h-1.5 overflow-hidden">
                                <div class="bg-accent-400 h-full rounded-full" style="width:@(fp.SoldQuantity * 100 / (fp.MaxQuantity > 0 ? fp.MaxQuantity : 1))%"></div>
                            </div>
                            <p class="text-white text-xs mt-1">Đã bán @fp.SoldQuantity / @fp.MaxQuantity</p>
                        </div>
                    </div>
                    <div class="p-3">
                        <p class="text-xs text-gray-400 truncate">@fp.Product.Supermarket?.Name</p>
                        <h3 class="text-sm font-semibold text-gray-900 dark:text-white truncate mt-1">@fp.Product.Name</h3>
                        <div class="flex items-center gap-2 mt-2">
                            <span class="text-base font-bold text-red-500">@fp.SalePrice.ToString("N0")đ</span>
                            <span class="text-xs text-gray-400 line-through">@fp.Product.OriginalPrice.ToString("N0")đ</span>
                        </div>
                        <button onclick="addToCart(@fp.Product.Id)" class="w-full mt-2 py-2 bg-primary-500 text-white text-sm font-medium rounded-lg hover:bg-primary-600 transition-colors">
                            <i class="fas fa-shopping-cart mr-1"></i> Mua ngay
                        </button>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-20 bg-white dark:bg-gray-800 rounded-2xl shadow-sm">
            <div class="w-20 h-20 bg-gray-100 dark:bg-gray-700 rounded-full flex items-center justify-center mx-auto mb-4">
                <i class="fas fa-clock text-3xl text-gray-400"></i>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Hiện không có Flash Sale</h3>
            <p class="text-sm text-gray-500 mt-1">Quay lại sau để không bỏ lỡ ưu đãi!</p>
        </div>
    }
</div>
