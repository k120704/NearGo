@page
@model NearGo.Pages.Admin.CategoriesModel
@{
    ViewData["Title"] = "Quản lý danh mục";
    Layout = "_AdminLayout";
}
<style>
    .modal-overlay { display: none; }
    .modal-overlay.show { display: flex; }
</style>
@if (TempData["Success"] != null)
{
    <div class="mb-4 p-3 bg-green-100 text-green-700 rounded-lg text-sm">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="mb-4 p-3 bg-red-100 text-red-700 rounded-lg text-sm">@TempData["Error"]</div>
}
<div class="bg-white dark:bg-gray-800 rounded-2xl p-6 shadow-sm border border-gray-100 dark:border-gray-700">
    <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Danh mục (@Model.Categories.Count)</h2>
        <button onclick="showModal()" class="px-3 py-1.5 text-sm bg-primary-500 text-white rounded-lg hover:bg-primary-600">
            <i class="fas fa-plus"></i> Thêm danh mục
        </button>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead>
                <tr class="text-left text-gray-500 border-b border-gray-100 dark:border-gray-700">
                    <th class="pb-3 font-medium w-10">Icon</th>
                    <th class="pb-3 font-medium">Tên</th>
                    <th class="pb-3 font-medium">Slug</th>
                    <th class="pb-3 font-medium">Mô tả</th>
                    <th class="pb-3 font-medium w-16">Thứ tự</th>
                    <th class="pb-3 font-medium w-16">SP</th>
                    <th class="pb-3 font-medium w-20">Trạng thái</th>
                    <th class="pb-3 font-medium w-24">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Categories.Any())
                {
                    <tr><td colspan="8" class="py-8 text-center text-gray-400">Chưa có danh mục nào</td></tr>
                }
                @foreach (var cat in Model.Categories)
                {
                    <tr class="border-b border-gray-50 dark:border-gray-800">
                        <td class="py-3"><i class="@cat.IconClass text-primary-500 text-lg"></i></td>
                        <td class="py-3 font-medium text-gray-900 dark:text-white">@cat.Name</td>
                        <td class="py-3 text-gray-500">@cat.Slug</td>
                        <td class="py-3 text-gray-500 max-w-40 truncate">@(cat.Description ?? "—")</td>
                        <td class="py-3 text-gray-500">@cat.SortOrder</td>
                        <td class="py-3 text-gray-500">@cat.Products.Count</td>
                        <td class="py-3">
                            <span class="px-2 py-0.5 rounded-full text-xs @(cat.IsActive ? "bg-green-100 text-green-600" : "bg-red-100 text-red-600")">
                                @(cat.IsActive ? "Hiện" : "Ẩn")
                            </span>
                        </td>
                        <td class="py-3">
                            <div class="flex gap-1">
                                <button type="button" onclick='editCategory(@cat.Id, "@cat.Name", "@cat.Slug", "@(cat.Description ?? "")", "@cat.IconClass", @cat.SortOrder, @(cat.IsActive ? "true" : "false"))'
                                        class="px-2 py-1 text-xs rounded-lg bg-blue-100 text-blue-700 hover:bg-blue-200 transition-colors">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <form method="post" asp-page-handler="Delete" class="inline" style="display:inline">
                                    <input type="hidden" name="id" value="@cat.Id" />
                                    <input type="hidden" name="name" value="@cat.Name" />
                                    <button type="button" onclick="confirmDelete(this)" class="px-2 py-1 text-xs rounded-lg bg-red-100 text-red-700 hover:bg-red-200 transition-colors">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div id="categoryModal" class="fixed inset-0 z-50 items-center justify-center bg-black/50 modal-overlay">
        <div class="bg-white dark:bg-gray-800 rounded-2xl p-6 w-full max-w-lg mx-4 shadow-xl">
            <h3 id="modalTitle" class="text-lg font-semibold mb-4 text-gray-900 dark:text-white">Thêm danh mục</h3>
            <form id="categoryForm" method="post">
                <input type="hidden" name="id" id="fieldId" value="0" />
                <div class="space-y-3">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Tên *</label>
                        <input type="text" name="name" id="fieldName" required
                               class="w-full px-3 py-2 text-sm border border-gray-200 dark:border-gray-700 rounded-lg bg-gray-50 dark:bg-gray-900 focus:ring-2 focus:ring-primary-500 outline-none" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Slug <span class="text-gray-400 font-normal">(để trống để tự tạo)</span></label>
                        <input type="text" name="slug" id="fieldSlug"
                               class="w-full px-3 py-2 text-sm border border-gray-200 dark:border-gray-700 rounded-lg bg-gray-50 dark:bg-gray-900 focus:ring-2 focus:ring-primary-500 outline-none" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Icon class</label>
                        <input type="text" name="iconClass" id="fieldIcon" placeholder="fas fa-tag"
                               class="w-full px-3 py-2 text-sm border border-gray-200 dark:border-gray-700 rounded-lg bg-gray-50 dark:bg-gray-900 focus:ring-2 focus:ring-primary-500 outline-none" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Mô tả</label>
                        <textarea name="description" id="fieldDesc" rows="2"
                                  class="w-full px-3 py-2 text-sm border border-gray-200 dark:border-gray-700 rounded-lg bg-gray-50 dark:bg-gray-900 focus:ring-2 focus:ring-primary-500 outline-none"></textarea>
                    </div>
                    <div class="flex gap-3">
                        <div class="flex-1">
                            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Thứ tự</label>
                            <input type="number" name="sortOrder" id="fieldSort" value="0"
                                   class="w-full px-3 py-2 text-sm border border-gray-200 dark:border-gray-700 rounded-lg bg-gray-50 dark:bg-gray-900 focus:ring-2 focus:ring-primary-500 outline-none" />
                        </div>
                        <div class="flex-1">
                            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Trạng thái</label>
                            <select name="isActive" id="fieldActive"
                                    class="w-full px-3 py-2 text-sm border border-gray-200 dark:border-gray-700 rounded-lg bg-gray-50 dark:bg-gray-900 focus:ring-2 focus:ring-primary-500 outline-none">
                                <option value="true">Hiện</option>
                                <option value="false">Ẩn</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="flex justify-end gap-2 mt-5">
                    <button type="button" onclick="hideModal()" class="px-4 py-2 text-sm rounded-lg bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 hover:bg-gray-200">Hủy</button>
                    <button type="submit" id="modalSubmit" class="px-4 py-2 text-sm bg-primary-500 text-white rounded-lg hover:bg-primary-600">Thêm</button>
                </div>
            </form>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        function showModal() {
            document.getElementById('modalTitle').textContent = 'Thêm danh mục';
            document.getElementById('categoryForm').action = '?handler=Create';
            document.getElementById('modalSubmit').textContent = 'Thêm';
            document.getElementById('fieldId').value = '0';
            document.getElementById('fieldName').value = '';
            document.getElementById('fieldSlug').value = '';
            document.getElementById('fieldIcon').value = 'fas fa-tag';
            document.getElementById('fieldDesc').value = '';
            document.getElementById('fieldSort').value = '0';
            document.getElementById('fieldActive').value = 'true';
            document.getElementById('categoryModal').classList.add('show');
        }
        function editCategory(id, name, slug, desc, icon, sort, active) {
            document.getElementById('modalTitle').textContent = 'Sửa danh mục';
            document.getElementById('categoryForm').action = '?handler=Update';
            document.getElementById('modalSubmit').textContent = 'Cập nhật';
            document.getElementById('fieldId').value = id;
            document.getElementById('fieldName').value = name;
            document.getElementById('fieldSlug').value = slug;
            document.getElementById('fieldIcon').value = icon;
            document.getElementById('fieldDesc').value = desc;
            document.getElementById('fieldSort').value = sort;
            document.getElementById('fieldActive').value = active ? 'true' : 'false';
            document.getElementById('categoryModal').classList.add('show');
        }
        function hideModal() {
            document.getElementById('categoryModal').classList.remove('show');
        }
        function confirmDelete(btn) {
            const form = btn.closest('form');
            const name = form.querySelector('input[name="name"]').value;
            Swal.fire({
                title: 'Xóa danh mục?',
                text: `Danh mục "${name}" sẽ bị xóa vĩnh viễn.`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc2626',
                cancelButtonColor: '#6b7280',
                confirmButtonText: 'Xóa',
                cancelButtonText: 'Hủy',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) form.submit();
            });
        }
        document.getElementById('categoryModal').addEventListener('click', function (e) {
            if (e.target === this) hideModal();
        });
    </script>
}
