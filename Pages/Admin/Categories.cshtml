@page
@model NearGo.Pages.Admin.CategoriesModel
@{
    ViewData["Title"] = "Quản lý danh mục";
    Layout = "_AdminLayout";
}
<div class="bg-white dark:bg-gray-800 rounded-2xl p-6 shadow-sm border border-gray-100 dark:border-gray-700">
    <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Danh mục (@Model.Categories.Count)</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        @foreach (var cat in Model.Categories)
        {
            <div class="p-4 bg-gray-50 dark:bg-gray-700/50 rounded-xl">
                <div class="flex items-center gap-2 mb-2">
                    <i class="@cat.IconClass text-primary-500"></i>
                    <span class="font-medium text-sm text-gray-900 dark:text-white">@cat.Name</span>
                </div>
                <p class="text-xs text-gray-400">@cat.Products.Count sản phẩm</p>
            </div>
        }
    </div>
</div>
