@page
@model NearGo.Pages.Admin.UsersModel
@{
    ViewData["Title"] = "Quản lý người dùng";
    Layout = "_AdminLayout";
}
<div class="bg-white dark:bg-gray-800 rounded-2xl p-6 shadow-sm border border-gray-100 dark:border-gray-700">
    <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Người dùng (@Model.Users.Count)</h2>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead>
                <tr class="text-left text-gray-500 border-b border-gray-100 dark:border-gray-700">
                    <th class="pb-3 font-medium">Tên</th>
                    <th class="pb-3 font-medium">Email</th>
                    <th class="pb-3 font-medium">Vai trò</th>
                    <th class="pb-3 font-medium">Ngày tạo</th>
                    <th class="pb-3 font-medium">Trạng thái</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model.Users)
                {
                    <tr class="border-b border-gray-50 dark:border-gray-800">
                        <td class="py-3 text-gray-900 dark:text-white font-medium">@u.FullName</td>
                        <td class="py-3 text-gray-500">@u.Email</td>
                        <td class="py-3">
                            <span class="px-2 py-0.5 rounded-full text-xs @(u.Roles.Contains("Admin") ? "bg-purple-100 text-purple-600" : u.Roles.Contains("Supermarket") ? "bg-primary-100 text-primary-600" : "bg-gray-100 text-gray-600")">
                                @string.Join(", ", u.Roles)
                            </span>
                        </td>
                        <td class="py-3 text-gray-500 text-xs">@u.CreatedAt.ToString("dd/MM/yyyy")</td>
                        <td class="py-3">
                            <span class="px-2 py-0.5 rounded-full text-xs @(u.IsActive ? "bg-green-100 text-green-600" : "bg-red-100 text-red-600")">
                                @(u.IsActive ? "Hoạt động" : "Vô hiệu")
                            </span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
