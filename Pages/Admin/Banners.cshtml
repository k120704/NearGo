@page
@model NearGo.Pages.Admin.BannersModel
@{
    ViewData["Title"] = "Quản lý Banner";
    Layout = "_AdminLayout";
}
<div class="bg-white dark:bg-gray-800 rounded-2xl p-6 shadow-sm border border-gray-100 dark:border-gray-700">
    <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Quản lý Banner (@Model.TotalCount)</h2>

    <div class="flex flex-wrap gap-2 mb-6">
        <a href="/admin/banners" class="px-4 py-2 text-sm rounded-xl @(string.IsNullOrEmpty(Model.Filter) ? "bg-primary-500 text-white" : "bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300")">Tất cả</a>
        <a href="/admin/banners?filter=Pending" class="px-4 py-2 text-sm rounded-xl @(Model.Filter == "Pending" ? "bg-yellow-500 text-white" : "bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300")">Chờ duyệt</a>
        <a href="/admin/banners?filter=Approved" class="px-4 py-2 text-sm rounded-xl @(Model.Filter == "Approved" ? "bg-green-500 text-white" : "bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300")">Đã duyệt</a>
        <a href="/admin/banners?filter=Rejected" class="px-4 py-2 text-sm rounded-xl @(Model.Filter == "Rejected" ? "bg-red-500 text-white" : "bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300")">Từ chối</a>
        <a href="/admin/banners?filter=Active" class="px-4 py-2 text-sm rounded-xl @(Model.Filter == "Active" ? "bg-blue-500 text-white" : "bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300")">Đang hiển thị</a>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead>
                <tr class="text-left text-gray-500 border-b border-gray-100 dark:border-gray-700">
                    <th class="pb-3 font-medium">Banner</th>
                    <th class="pb-3 font-medium">Siêu thị</th>
                    <th class="pb-3 font-medium">Trạng thái</th>
                    <th class="pb-3 font-medium">Hiển thị</th>
                    <th class="pb-3 font-medium">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Banners.Any())
                {
                    <tr><td colspan="5" class="py-8 text-center text-gray-400">Không có banner nào</td></tr>
                }
                @foreach (var b in Model.Banners)
                {
                    <tr class="border-b border-gray-50 dark:border-gray-800">
                        <td class="py-3">
                            <div class="flex items-center gap-3">
                                <div class="relative group cursor-pointer flex-shrink-0" onclick="previewBanner('@b.ImageUrl', '@b.Title', '@(b.Subtitle ?? "")')">
                                    <img src="@b.ImageUrl" alt="@b.Title" class="w-20 h-12 object-cover rounded-lg" />
                                    <div class="absolute inset-0 bg-black/40 rounded-lg flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                                        <i class="fas fa-search-plus text-white text-sm"></i>
                                    </div>
                                </div>
                                <div>
                                    <p class="font-medium text-gray-900 dark:text-white">@b.Title</p>
                                    <p class="text-xs text-gray-400">@b.Subtitle</p>
                                    <p class="text-xs text-gray-400 mt-0.5">
                                        @b.CreatedAt.ToString("dd/MM/yyyy")
                                        @if (b.PackageDays > 0)
                                        {
                                            <span class="ml-1 text-primary-500">@b.PackageDays ngày - @b.PackagePrice:N0đ</span>
                                        }
                                    </p>
                                </div>
                            </div>
                        </td>
                        <td class="py-3 text-gray-500">@b.Supermarket?.Name</td>
                        <td class="py-3">
                            @{
                                var sc = b.Status switch
                                {
                                    "Approved" => "bg-green-100 text-green-600",
                                    "Rejected" => "bg-red-100 text-red-600",
                                    _ => "bg-yellow-100 text-yellow-600"
                                };
                                var st = b.Status switch
                                {
                                    "Approved" => "Đã duyệt",
                                    "Rejected" => "Từ chối",
                                    _ => "Chờ duyệt"
                                };
                            }
                            <span class="px-2 py-0.5 rounded-full text-xs font-medium @sc">@st</span>
                        </td>
                        <td class="py-3">
                            @if (b.Status == "Approved")
                            {
                                <form method="post" asp-page-handler="ToggleActive" class="inline">
                                    <input type="hidden" name="id" value="@b.Id" />
                                    @if (b.IsActive)
                                    {
                                        <button type="submit" class="px-2.5 py-1.5 text-xs rounded-lg font-medium bg-orange-100 text-orange-600 hover:bg-orange-200 transition-colors"
                                                onclick="return confirm('Ẩn banner này khỏi website?')">
                                            <i class="fas fa-eye-slash mr-1"></i> Ẩn
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="submit" class="px-2.5 py-1.5 text-xs rounded-lg font-medium bg-emerald-100 text-emerald-600 hover:bg-emerald-200 transition-colors">
                                            <i class="fas fa-globe mr-1"></i> Đưa lên website
                                        </button>
                                    }
                                </form>
                            }
                            else
                            {
                                <span class="text-xs text-gray-400">—</span>
                            }
                        </td>
                        <td class="py-3">
                            <div class="flex items-center gap-1">
                                @if (b.Status == "Pending" && b.PaymentStatus == "Paid")
                                {
                                    <form method="post" asp-page-handler="Approve" class="inline">
                                        <input type="hidden" name="id" value="@b.Id" />
                                        <button type="submit" class="px-2.5 py-1.5 text-xs bg-emerald-100 text-emerald-600 rounded-lg hover:bg-emerald-200 transition-colors font-medium">
                                            <i class="fas fa-check mr-1"></i> Duyệt
                                        </button>
                                    </form>
                                    <form method="post" asp-page-handler="Reject" class="inline">
                                        <input type="hidden" name="id" value="@b.Id" />
                                        <input type="text" name="note" placeholder="Lý do..." class="w-20 px-2 py-1.5 text-xs border border-gray-200 dark:border-gray-600 rounded-lg bg-gray-50 dark:bg-gray-700" />
                                        <button type="submit" class="px-2 py-1.5 text-xs bg-red-100 text-red-600 rounded-lg hover:bg-red-200 transition-colors">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </form>
                                }
                                else if (b.Status == "Approved" && b.IsActive)
                                {
                                    <form method="post" asp-page-handler="MoveUp" class="inline">
                                        <input type="hidden" name="id" value="@b.Id" />
                                        <button type="submit" class="px-2 py-1.5 text-xs bg-gray-100 text-gray-600 rounded-lg hover:bg-gray-200 transition-colors" title="Lên trước">
                                            <i class="fas fa-arrow-up"></i>
                                        </button>
                                    </form>
                                    <form method="post" asp-page-handler="MoveDown" class="inline">
                                        <input type="hidden" name="id" value="@b.Id" />
                                        <button type="submit" class="px-2 py-1.5 text-xs bg-gray-100 text-gray-600 rounded-lg hover:bg-gray-200 transition-colors" title="Xuống sau">
                                            <i class="fas fa-arrow-down"></i>
                                        </button>
                                    </form>
                                }
                                @if (b.Status != "Approved" || !b.IsActive)
                                {
                                    <form method="post" asp-page-handler="Delete" class="inline">
                                        <input type="hidden" name="id" value="@b.Id" />
                                        <button type="submit" class="px-2 py-1.5 text-xs bg-red-100 text-red-600 rounded-lg hover:bg-red-200 transition-colors"
                                                onclick="return confirm('Xóa banner này?')" title="Xóa">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@* Preview Modal *@
<div id="previewModal" class="fixed inset-0 z-50 bg-black/80 flex items-center justify-center hidden" onclick="closePreview()">
    <div class="relative max-w-5xl mx-4 w-full" onclick="event.stopPropagation()">
        <button onclick="closePreview()" class="absolute -top-10 right-0 text-white/60 hover:text-white text-lg">
            <i class="fas fa-times"></i>
        </button>
        <div class="rounded-2xl overflow-hidden shadow-2xl">
            <img id="previewImage" src="" alt="" class="w-full h-auto max-h-[70vh] object-cover" />
            <div class="bg-white dark:bg-gray-800 p-5">
                <h3 id="previewTitle" class="text-lg font-semibold text-gray-900 dark:text-white"></h3>
                <p id="previewSubtitle" class="text-sm text-gray-500 dark:text-gray-400 mt-1"></p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function previewBanner(url, title, subtitle) {
            document.getElementById('previewImage').src = url;
            document.getElementById('previewImage').alt = title;
            document.getElementById('previewTitle').textContent = title;
            document.getElementById('previewSubtitle').textContent = subtitle;
            document.getElementById('previewModal').classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        }
        function closePreview() {
            document.getElementById('previewModal').classList.add('hidden');
            document.body.style.overflow = '';
        }
        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') closePreview();
        });
    </script>
}
