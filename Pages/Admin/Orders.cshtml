@page
@model NearGo.Pages.Admin.OrdersModel
@{
    ViewData["Title"] = "Quản lý đơn hàng";
    Layout = "_AdminLayout";
}
<div class="bg-white dark:bg-gray-800 rounded-2xl p-6 shadow-sm border border-gray-100 dark:border-gray-700">
    <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Đơn hàng (@Model.Orders.Count)</h2>
    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead>
                <tr class="text-left text-gray-500 border-b border-gray-100 dark:border-gray-700">
                    <th class="pb-3 font-medium">Mã</th>
                    <th class="pb-3 font-medium">Khách</th>
                    <th class="pb-3 font-medium">Siêu thị</th>
                    <th class="pb-3 font-medium">Tổng</th>
                    <th class="pb-3 font-medium">TT</th>
                    <th class="pb-3 font-medium">Trạng thái</th>
                    <th class="pb-3 font-medium">Ngày</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var o in Model.Orders)
                {
                    <tr class="border-b border-gray-50 dark:border-gray-800">
                        <td class="py-3 font-medium text-gray-900 dark:text-white">#@o.OrderCode</td>
                        <td class="py-3 text-gray-500">@o.Customer?.FullName</td>
                        <td class="py-3 text-gray-500">@o.Supermarket?.Name</td>
                        <td class="py-3 text-gray-900 dark:text-white font-medium">@o.TotalAmount.ToString("N0")đ</td>
                        <td class="py-3"><span class="px-2 py-0.5 rounded-full text-xs @(o.PaymentStatus == "Paid" ? "bg-green-100 text-green-600" : "bg-yellow-100 text-yellow-600")">@o.PaymentStatus</span></td>
                        <td class="py-3"><span class="px-2 py-0.5 rounded-full text-xs bg-blue-100 text-blue-600">@o.Status</span></td>
                        <td class="py-3 text-gray-500 text-xs">@o.OrderDate.ToString("dd/MM")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
